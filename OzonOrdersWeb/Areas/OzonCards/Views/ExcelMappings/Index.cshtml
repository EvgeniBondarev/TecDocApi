@model IEnumerable<OzonDomains.ExcelMapping>

@{
    ViewData["Title"] = "Управление шаблонами Excel";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="fas fa-table me-2"></i>Шаблоны Excel маппингов
                </h4>
                <a href="@Url.Action("Index", "Excel", new { area = "OzonCards" })" class="btn btn-light btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>Назад к обработке
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-table fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Шаблоны не найдены</h5>
                    <p class="text-muted">Создайте свой первый шаблон для сопоставления Excel файлов</p>
                    <a href="@Url.Action("Index", "Excel", new { area = "OzonCards" })" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Создать шаблон
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Название</th>
                                <th>Исходный файл</th>
                                <th>Целевой файл</th>
                                <th>Листы</th>
                                <th>Создан</th>
                                <th>Автор</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mapping in Model)
                            {
                                <tr id="mapping-@mapping.Id">
                                    <td>
                                        <strong>@mapping.Name</strong>
                                    </td>
                                    <td>
                                        <small class="text-muted">@System.IO.Path.GetFileName(mapping.SourceFileName)</small>
                                    </td>
                                    <td>
                                        <small class="text-muted">@System.IO.Path.GetFileName(mapping.DestinationFileName)</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@mapping.SourceSheet</span>
                                        <i class="fas fa-arrow-right text-muted mx-1"></i>
                                        <span class="badge bg-success">@mapping.DestinationSheet</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@mapping.CreatedDate.ToString("dd.MM.yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        <small class="text-muted">@mapping.CreatedBy</small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary load-mapping" data-id="@mapping.Id" title="Загрузить шаблон">
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <button class="btn btn-outline-danger delete-mapping" data-id="@mapping.Id" data-name="@mapping.Name" title="Удалить шаблон">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Подтверждение удаления</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Вы уверены, что хотите удалить шаблон "<strong id="deleteMappingName"></strong>"?</p>
                <p class="text-danger"><small>Это действие нельзя отменить.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">Удалить</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let currentMappingId = null;

            // Обработка загрузки шаблона
            $('.load-mapping').click(function() {
                const mappingId = $(this).data('id');
                window.location.href = '/OzonCards/Excel?mappingId=' + mappingId;
            });

            // Обработка удаления шаблона
            $('.delete-mapping').click(function() {
                currentMappingId = $(this).data('id');
                const mappingName = $(this).data('name');
                
                $('#deleteMappingName').text(mappingName);
                $('#deleteModal').modal('show');
            });

            // Подтверждение удаления
            $('#confirmDelete').click(function() {
                if (currentMappingId) {
                    deleteMapping(currentMappingId);
                }
            });

            // Функция загрузки шаблона
            function loadMapping(mappingId) {
                $.ajax({
                    url: '@Url.Action("Load", "ExcelMappings", new { area = "OzonCards" })?id=' + mappingId,
                    type: 'GET',
                    success: function(response) {
                        if (response.success) {
                            localStorage.setItem('excelMappingTemplate', JSON.stringify(response.data));
                            window.location.href = '@Url.Action("Index", "Excel", new { area = "OzonCards" })';
                        } else {
                            alert('Ошибка загрузки шаблона: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('Ошибка при загрузке шаблона');
                    }
                });
            }

            // Функция удаления шаблона
            function deleteMapping(mappingId) {
                $.ajax({
                    url: '@Url.Action("Delete", "ExcelMappings", new { area = "OzonCards" })?id=' + mappingId,
                    type: 'DELETE',
                    success: function(response) {
                        if (response.success) {
                            // Удаляем строку из таблицы
                            $('#mapping-' + mappingId).remove();
                            
                            // Показываем уведомление
                            showToast('Шаблон успешно удален', 'success');
                            
                            // Если таблица пустая, показываем сообщение
                            if ($('tbody tr').length === 0) {
                                location.reload();
                            }
                        } else {
                            alert('Ошибка удаления: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('Ошибка при удалении шаблона');
                    },
                    complete: function() {
                        $('#deleteModal').modal('hide');
                    }
                });
            }

            // Функция показа уведомления
            function showToast(message, type = 'info') {
                // Простая реализация toast уведомления
                const toast = document.createElement('div');
                toast.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
                toast.style.cssText = 'top: 20px; right: 20px; z-index: 1050; min-width: 300px;';
                toast.innerHTML = `
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                
                document.body.appendChild(toast);
                
                // Автоматическое скрытие через 3 секунды
                setTimeout(() => {
                    toast.remove();
                }, 3000);
            }
        });
    </script>

    <style>
        .table th {
            border-top: none;
            font-weight: 600;
        }
        
        .badge {
            font-size: 0.75em;
        }
        
        .btn-group-sm > .btn {
            padding: 0.25rem 0.5rem;
        }
        
        .load-mapping:hover {
            background-color: #0d6efd;
            color: white;
        }
        
        .delete-mapping:hover {
            background-color: #dc3545;
            color: white;
        }
        
        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }
    </style>
}