@using OzonDomains.Models
@using OzonOrdersWeb.ViewModels.AppStatusViewModels
@using OzonOrdersWeb.ViewModels.SupplierViewModels
@using Servcies.FiltersServcies.FilterModels
@using Servcies.FiltersServcies.SortModels

@model AppStatusViewModel<AppStatus, AppStatusFilterModel>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script asp-src-include="~/js/**/*.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
    .table td:first-child, .table th:first-child {
        width: 1px;
        white-space: nowrap;
    }
    
    .color-picker-cell {
        width: 100px;
    }
</style>

<div class="container">
    <div class="row">
        <div>
            <div class="card">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h2>Статусы</h2>
                        <p>
                            <a asp-action="Create">Создать cтатус</a>
                        </p>
                    </div>
                    <button type="button" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#exampleModal" type="submit" style="width: 18px; height: 18px; margin-left: auto;" title="Настройка отображения таблицы">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear-fill" viewBox="0 0 16 16">
                            <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z" />
                        </svg>
                    </button>
                </div>
                <div class="card-body">
                    <table class="table" id="mainTable">
                        <thead>
                            <tr>
                                <th>
                                    <form asp-area="Studio2" asp-controller="AppStatus" asp-action="DelSortStateCookie" method="post">
                                        <button type="submit" class="btn btn-link" style="width: 18px; height: 18px;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
                                                <path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0"></path>
                                            </svg>
                                        </button>
                                    </form>
                                </th>
                                <th>
                                    <a class="text-dark" asp-action="Index" asp-route-sortOrder="@ViewBag.AppStatusSortNameSort">
                                        <small>@(ViewBag.AppStatusSortNameSort == AppStatusSortState.NameAsc ? "Статус в отчете↑" : "Статус в отчете↓")</small>
                                    </a>
                                </th>
                                <th class="color-picker-cell">Цвет</th>
                                <th>Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <form id="filterForm" asp-area="Studio2" asp-controller="AppStatus" asp-action="Index" method="post">
                                <td>
                                    <button type="button" class="btn btn-link ml-2" onclick="clearForm()" style="margin-top: -9px;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
                                            <path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0"></path>
                                        </svg>
                                    </button>
                                </td>
                                <td>
                                    <input asp-for="@Model.FilterModel.Name" id="nameFilter" name="Name" class="form-control form-control-sm" />
                                </td>
                                <td></td>
                                <td></td>
                                <button type="submit" id="submitFilterButton" style="display:none;"></button>
                                </form>
                            </tr>
                            @foreach (var item in Model.Items)
                            {
                                var color = item.StatusColor?.ColorCode ?? "#ffffff";
                                <tr data-status-id="@item.Id">
                                    <td></td>
                                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                                    <td class="color-picker-cell">
                                        <input type="color" class="form-control form-control-color status-color" value="@color" style="width: 75px;" title="Выберите цвет" />
                                    </td>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
    
                                            <button class="btn btn-danger btn-sm reset-color">Сбросить цвет</button>
    
                                            @if (item.Name != "Заказан поставщику")
                                            {
                                                <a class="btn btn-sm btn-primary"
                                                   asp-action="Delete"
                                                   asp-route-id="@item.Id"
                                                   onclick="return confirm('Вы уверены, что хотите удалить?');">
                                                    Удалить
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        // Обработчик изменения цвета
        $(document).on('change', '.status-color', function () {
            let statusId = $(this).closest('tr').data('status-id');
            let colorCode = $(this).val();

            $.post('@Url.Action("UpdateStatusColor", "AppStatus", new { area = "Studio2" })',
                { statusId: statusId, colorCode: colorCode },
                function (res) {
                    if (!res.success) {
                        alert("Ошибка сохранения цвета");
                    }
                });
        });

        // Обработчик сброса цвета
        $(document).on('click', '.reset-color', function () {
            let statusId = $(this).closest('tr').data('status-id');
            let colorInput = $(this).closest('tr').find('.status-color');

            $.post('@Url.Action("ResetStatusColor", "AppStatus", new { area = "Studio2" })',
                { statusId: statusId },
                function (res) {
                    if (res.success) {
                        colorInput.val('#ffffff');
                    } else {
                        alert("Ошибка сброса цвета");
                    }
                });
        });
    });
</script>
}