                    @if (Model.Orders[i].CartItemStatus != null)
                    {
                        <div class="text-info text-muted nowrap" style="font-size: 13px;"  title="@Model.Orders[i].CartItemStatus.Name">
                            @{
                                string cartStatus = Model.Orders[i].CartItemStatus.Name;
                                if (cartStatus.Length > 14)
