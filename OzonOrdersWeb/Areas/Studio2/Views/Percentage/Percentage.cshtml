                                    console.error(`Ошибка загрузки zzapData для заказа ${orderId}:`, error);
                                })
                        );
                    }

                    if (selectedTypes.includes('bitrixData') && !orderDataCache[orderId]?.bitrixData) {
                        requests.push(
                            fetchBitrixData(orderArticle)
                                .then(data => {
                                    if (data && data.length > 0) {
                                        processBitrixData(data, orderId);
                                        loadedTypes.push('bitrixData');
                                        console.log(`Фоновая загрузка: bitrixData для заказа ${orderId}`);
                                    }
                                })
                                .catch(error => {
                                    console.error(`Ошибка загрузки bitrixData для заказа ${orderId}:`, error);
                                })
                        );
                    }

                    // Если нет запросов для выполнения
                    if (requests.length === 0) {
                        console.log(`Все выбранные данные уже загружены в кэш для заказа ${orderId}`);
                        return;
                    }

                    console.log(`Начинается фоновая загрузка ${requests.length} типов данных для заказа ${orderId}`);

                    // Ожидаем завершения всех запросов
                    await Promise.allSettled(requests); // Используем allSettled вместо all для обработки ошибок

                    // Логируем результаты загрузки
                    if (loadedTypes.length > 0) {
                        console.log(`Успешно загружены типы данных: ${loadedTypes.join(', ')} для заказа ${orderId}`);
                    } else {
                        console.log(`Не удалось загрузить данные для заказа ${orderId} (все запросы завершились с ошибкой или пустыми данными)`);
                    }

                    // Обновляем счетчик загруженных данных в интерфейсе (если нужно)
                    updateBackgroundLoadStats(orderId, loadedTypes.length);

                } catch (error) {
                    console.error("Критическая ошибка при фоновой загрузке данных:", error);
                } finally {
                    button.disabled = false;
                }
            }
            
