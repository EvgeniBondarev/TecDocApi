                    <div class="form-check d-flex align-items-center">
                        <input class="form-check-input data-type-checkbox" type="checkbox" id="tradesoftCheck" data-type="tradesoftData" checked>
                        <label class="form-check-label ms-2" for="tradesoftCheck">Tradesoft данные</label>
                    </div>
                </li>
                <li>
                    <div class="form-check d-flex align-items-center">
                        <input class="form-check-input data-type-checkbox" type="checkbox" id="abcpCheck" data-type="abcpData" checked>
                        <label class="form-check-label ms-2" for="abcpCheck">ABCP данные</label>
                    </div>
                </li>
                <li>
                    <div class="form-check d-flex align-items-center">
                        <input class="form-check-input data-type-checkbox" type="checkbox" id="avdCheck" data-type="avdData" checked>
                        <label class="form-check-label ms-2" for="avdCheck">AVD данные</label>
                    </div>
                </li>
                <li>
                    <div class="form-check d-flex align-items-center">
                        <input class="form-check-input data-type-checkbox" type="checkbox" id="zzapCheck" data-type="zzapData" checked>
                        <label class="form-check-label ms-2" for="zzapCheck">ZZAP данные</label>
                    </div>
                </li>
                <li>
                    <div class="form-check d-flex align-items-center">
                        <input class="form-check-input data-type-checkbox" type="checkbox" id="bitrixCheck" data-type="bitrixData" checked>
                        <label class="form-check-label ms-2" for="bitrixCheck">Bitrix данные</label>
                    </div>
                </li>
                <li class="mt-2 d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="selectAllData">Выбрать все</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="deselectAllData">Снять все</button>
                </li>
            </ul>
        </div>

    <!-- Селект региона -->
    <div class="form-group mb-0">
        <label for="regionSelect" class="form-label visually-hidden">Регион</label>
        <select id="regionSelect" name="RegionCode" class="form-select form-select-sm">
            <option value="1" selected>Россия, Москва и область</option>
        </select>
    </div>
</div>

<script>
// Выбор / снятие всех чекбоксов
const selectAllBtn = document.getElementById('selectAllData');
const deselectAllBtn = document.getElementById('deselectAllData');
const checkboxes = document.querySelectorAll('.data-type-checkbox');

selectAllBtn.addEventListener('click', () => checkboxes.forEach(cb => cb.checked = true));
deselectAllBtn.addEventListener('click', () => checkboxes.forEach(cb => cb.checked = false));

// Переключение чекбокса при клике на label и не закрывать dropdown
document.querySelectorAll('.dropdown-menu .form-check-label').forEach(label => {
    label.addEventListener('click', e => {
        e.preventDefault(); // предотвращает переход/закрытие
        const checkbox = document.getElementById(label.getAttribute('for'));
        checkbox.checked = !checkbox.checked;
    });
});
document.querySelectorAll('.dropdown-menu .form-check-input').forEach(cb => {
    cb.addEventListener('click', e => e.stopPropagation()); // чтобы dropdown не закрывался
});
</script>


