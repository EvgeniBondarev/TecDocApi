<script>
    $(document).ready(function () {
        // Функция для установки куки
        function setCookie(cname, cvalue, exdays) {
            var d = new Date();
            d.setTime(d.getTime() + (exdays * 24 * 60 * 60 * 1000));
            var expires = "expires=" + d.toUTCString();
            document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
        }

        // Функция для получения значения куки
        function getCookie(cname) {
            var name = cname + "=";
            var decodedCookie = decodeURIComponent(document.cookie);
            var ca = decodedCookie.split(';');
            for (var i = 0; i < ca.length; i++) {
                var c = ca[i];
                while (c.charAt(0) == ' ') {
                    c = c.substring(1);
                }
                if (c.indexOf(name) == 0) {
                    return c.substring(name.length, c.length);
                }
            }
            return "";
        }

        // При загрузке страницы проверяем, был ли установлен куки для подсветки
        var highlightedColumn = getCookie("HighlightedColumn");
        if (highlightedColumn != "") {
            $('#' + highlightedColumn).addClass('active');
        }

        // Обработчик события клика
        $('th a').click(function () {
            // Удаляем класс active у всех заголовков столбцов
            $('th').removeClass('active');
            // Добавляем класс active к текущему заголовку столбца
            var columnId = $(this).closest('th').attr('id');
            $('#' + columnId).addClass('active');
            // Сохраняем id подсвеченного столбца в куки на 1 день
            setCookie("HighlightedColumn", columnId, 1);
        });
    });

    function showSplitOptions(itemId, quantity) {
        // Создаем модальное окно
        let modal = document.createElement('div');
        modal.style.position = 'fixed';
        modal.style.top = '0';
        modal.style.left = '0';
        modal.style.width = '100%';
        modal.style.height = '100%';
        modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
        modal.style.display = 'flex';
        modal.style.justifyContent = 'center';
        modal.style.alignItems = 'center';
        modal.style.zIndex = '1000';

        // Создаем контент модального окна
        let content = document.createElement('div');
        content.style.backgroundColor = 'white';
        content.style.padding = '25px';
        content.style.borderRadius = '8px';
        content.style.maxWidth = '500px';
        content.style.width = '90%';
        content.style.boxShadow = '0 4px 6px rgba(0, 0, 0, 0.1)';
        content.style.maxHeight = '80vh';
        content.style.overflowY = 'auto';

        let title = document.createElement('h4');
        title.textContent = 'Разделение заказа';
        title.style.marginTop = '0';
        title.style.marginBottom = '20px';
        title.style.color = '#333';
        title.style.fontWeight = '600';
        content.appendChild(title);

        let description = document.createElement('p');
        description.textContent = `Выберите как разделить заказ (${quantity} шт.):`;
        description.style.marginBottom = '15px';
        description.style.color = '#666';
        content.appendChild(description);

        let optionsDiv = document.createElement('div');
        optionsDiv.style.margin = '15px 0';
        optionsDiv.style.display = 'grid';
        optionsDiv.style.gridTemplateColumns = 'repeat(auto-fill, minmax(100px, 1fr))';
        optionsDiv.style.gap = '10px';

        // Генерируем все возможные варианты разделения
        for (let i = 1; i < quantity; i++) {
            let option = document.createElement('button');
            option.textContent = `${i} + ${quantity - i}`;
            option.style.padding = '10px 15px';
            option.style.borderRadius = '5px';
            option.style.cursor = 'pointer';
            option.style.transition = 'all 0.2s';
            option.style.border = '1px solid #007bff';
            option.style.background = 'none';
            option.style.color = '#007bff'; // Цвет текста как у границы
            option.style.display = 'flex';
            option.style.justifyContent = 'center';
            option.style.alignItems = 'center';
            option.style.flexDirection = 'column';

            // Подсветка при наведении
            option.onmouseover = function() {
                this.style.backgroundColor = '#007bff';
                this.style.color = 'white'; // Белый текст только при наведении
            };
            option.onmouseout = function() {
                this.style.backgroundColor = 'transparent';
                this.style.color = '#007bff'; // Возвращаем исходный цвет текста
            };

            option.onclick = function() {
                let page = @Model.PageNumber;
                window.location.href = `/Studio2/Orders/SplitOrder?ids=${itemId}&page=${page}&splitOption=${i}+${quantity-i}`;
            };

            optionsDiv.appendChild(option);
        }

        content.appendChild(optionsDiv);

        // Группа кнопок внизу
        let buttonGroup = document.createElement('div');
        buttonGroup.style.display = 'flex';
        buttonGroup.style.justifyContent = 'flex-end';
        buttonGroup.style.marginTop = '20px';
        buttonGroup.style.gap = '10px';

        // Кнопка ручного ввода
        let customBtn = document.createElement('button');
        customBtn.textContent = 'Свой вариант';
        customBtn.style.padding = '8px 16px';
        customBtn.style.border = '1px solid #6c757d';
        customBtn.style.borderRadius = '5px';
        customBtn.style.background = 'none';
        customBtn.style.color = '#6c757d';
        customBtn.style.cursor = 'pointer';
        customBtn.style.transition = 'all 0.2s';
        customBtn.onmouseover = function() {
            this.style.backgroundColor = '#6c757d';
            this.style.color = 'white';
        };
        customBtn.onmouseout = function() {
            this.style.backgroundColor = 'transparent';
            this.style.color = '#6c757d';
        };
        customBtn.onclick = function() {
            let customValue = prompt(`Введите количество для первой части (всего ${quantity} шт.):`);
            if (customValue && !isNaN(customValue) && customValue > 0 && customValue < quantity) {
                let firstPart = parseInt(customValue);
                let page = @Model.PageNumber;
                window.location.href = `/Studio2/Orders/SplitOrder?ids=${itemId}&page=${page}&splitOption=${firstPart}+${quantity-firstPart}`;
            } else if (customValue !== null) {
                alert('Пожалуйста, введите корректное число между 1 и ' + (quantity-1));
            }
        };
        buttonGroup.appendChild(customBtn);

        // Кнопка отмены
        let cancelBtn = document.createElement('button');
        cancelBtn.textContent = 'Отмена';
        cancelBtn.style.padding = '8px 16px';
        cancelBtn.style.border = '1px solid #6c757d';
        cancelBtn.style.borderRadius = '5px';
        cancelBtn.style.background = 'none';
        cancelBtn.style.color = '#6c757d';
        cancelBtn.style.cursor = 'pointer';
        cancelBtn.style.transition = 'all 0.2s';
        cancelBtn.onmouseover = function() {
            this.style.backgroundColor = '#6c757d';
            this.style.color = 'white';
        };
        cancelBtn.onmouseout = function() {
            this.style.backgroundColor = 'transparent';
            this.style.color = '#6c757d';
        };
        cancelBtn.onclick = function() {
            document.body.removeChild(modal);
        };
        buttonGroup.appendChild(cancelBtn);

        content.appendChild(buttonGroup);

        modal.appendChild(content);
        document.body.appendChild(modal);

        // Закрытие по клику вне окна
        modal.onclick = function(e) {
            if (e.target === modal) {
                document.body.removeChild(modal);
            }
        };
    }
</script>
