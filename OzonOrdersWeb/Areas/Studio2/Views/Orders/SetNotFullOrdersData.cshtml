    function updateFieldsBasedOnPrice(index, price) {
        // Получаем элементы с исходными значениями
        const maxProfitElementRow = document.getElementById('maxProfit_origin_' + index);
        const minProfitElementRow = document.getElementById('minProfit_origin_' + index);
        const maxDiscountElementRow = document.getElementById('maxDiscount_origin_' + index);
        const minDiscountElementRow = document.getElementById('minDiscount_origin_' + index);
        const costPriceElement = document.getElementById('costPrice_origin_' + index);

        // Получаем элементы с комиссиями
        const minOzonCommissionElement = document.getElementById('minOzonCommission_hidden_' + index);
        const maxOzonCommissionElement = document.getElementById('maxOzonCommission_hidden_' + index);

        // Получаем элементы для обновления
        const maxProfitElement = document.getElementById('maxProfit_origin_' + index);
        const minProfitElement = document.getElementById('minProfit_origin_' + index);
        const maxDiscountElement = document.getElementById('maxDiscount_origin_' + index);
        const minDiscountElement = document.getElementById('minDiscount_origin_' + index);

        if (price == null || isNaN(price)) {
            // Если цена не задана, сбрасываем значения и стили
            if (maxProfitElement) {
                maxProfitElement.textContent = '';
                maxProfitElement.style.color = '';
            }
            if (minProfitElement) {
                minProfitElement.textContent = '';
                minProfitElement.style.color = '';
            }
            if (maxDiscountElement) {
                maxDiscountElement.textContent = '';
                maxDiscountElement.style.color = '';
            }
            if (minDiscountElement) {
                minDiscountElement.textContent = '';
                minDiscountElement.style.color = '';
            }
            return;
        }

        // Убедимся, что все элементы существуют
        if (maxProfitElementRow && minProfitElementRow && maxDiscountElementRow && minDiscountElementRow &&
            costPriceElement && minOzonCommissionElement && maxOzonCommissionElement) {

            const costPrice = parseFloat(costPriceElement.textContent.replace(/\s/g, '')) || 0;
            const minOzonCommission = parseFloat(minOzonCommissionElement.value.replace(/\s/g, '')) || 0;
            const maxOzonCommission = parseFloat(maxOzonCommissionElement.value.replace(/\s/g, '')) || 0;

            // Вычисляем значения
            const startCommission = price - costPrice;
            const newMinProfit = startCommission - maxOzonCommission;
            const newMaxProfit = startCommission - minOzonCommission;

            const newMinDiscount = (newMinProfit / costPrice) * 100 || 0;
            const newMaxDiscount = (newMaxProfit / costPrice) * 100 || 0;

            // Обновляем значения и стили
            if (maxProfitElement) {
                maxProfitElement.textContent = Math.round(newMaxProfit);
                maxProfitElement.style.color = newMaxProfit < 0 ? "red" : "";
            }

            if (minProfitElement) {
                minProfitElement.textContent = Math.round(newMinProfit);
                minProfitElement.style.color = newMinProfit < 0 ? "red" : "";
            }

            if (maxDiscountElement) {
                maxDiscountElement.textContent = Math.round(newMaxDiscount);
                maxDiscountElement.style.color = newMaxDiscount < 0 ? "red" : "";
            }

            if (minDiscountElement) {
                minDiscountElement.textContent = Math.round(newMinDiscount);
                minDiscountElement.style.color = newMinDiscount < 0 ? "red" : "";
            }
        } else {
            console.error('Некоторые элементы отсутствуют для индекса ' + index);
        }
    }

    // Пример использования
    document.querySelectorAll('[id^="priceFilter_"]').forEach(function (inputElement) {
        inputElement.addEventListener('input', function () {
            const elementId = this.id;
            const index = elementId.split('_')[1];
            const price = parseFloat(this.value.replace(/\s/g, ''));

            // Обновляем поля на основе новой цены
            updateFieldsBasedOnPrice(index, isNaN(price) ? null : price);
        });
    });
</script>

<script>
    function showToast(message) {
        const toastBody = document.getElementById('flashMessageText');
        toastBody.textContent = message;
        const toast = new bootstrap.Toast(document.getElementById('flashMessage'));
        toast.show();
    }

    let selectedRow = null; 


    function selectRowForMerge(event, index) {
        console.log(event.target.tagName)
        
        if (event.target.tagName === 'TD' ||
            event.target.tagName === 'DIV' ||
            event.target.tagName === 'SPAN') {
            const selectedRowElement = document.getElementById(`selectRowForMerge_${index}`);

            if (selectedRow === null) {
                selectedRow = index;

                if (selectedRowElement) {
                    selectedRowElement.classList.remove("table-info");
                    selectedRowElement.classList.add("table-warning");
                }

                showToast("Выберите строку для объединения с первой выбранной строкой.");
            } else {
                if (selectedRow === index) {
                    // Deselect the first row if clicked again
                    if (selectedRowElement) {
                        selectedRowElement.classList.add("table-info");
                        selectedRowElement.classList.remove("table-warning");
                    }
                    selectedRow = null;
                } else {
                    // Merge with the second row and reset the first row's highlight
                    mergeQuantities(selectedRow, index);
                    const firstRowElement = document.getElementById(`selectRowForMerge_${selectedRow}`);
                    if (firstRowElement) {
                        firstRowElement.classList.add("table-info");
                        firstRowElement.classList.remove("table-warning");
                    }
                    selectedRow = null;
                }
            }
        }
    }
    
    // Функция для объединения значений Quantity и скрытия строк ниже второй строки
    function mergeQuantities(firstIndex, secondIndex) {
        // Получаем вторую строку для проверки наличия выбранного чекбокса
        const secondRow = document.querySelector(`tr.quantity-row[data-index="${secondIndex}"]`);
        if (secondRow) {
            const checkboxInSecondRow = secondRow.querySelector('.record-checkbox');

            // Проверяем, если установлен чекбокс в самой второй строке
            if (checkboxInSecondRow && checkboxInSecondRow.checked) {
                showToast("Операция объединения прервана: выбрана строка для которой выбрано сопрставление.");
                return; // Прерываем функцию до внесения каких-либо изменений
            }

            // Проверяем строки ниже второй строки на наличие установленного чекбокса
            let nextRow = secondRow.nextElementSibling;
            while (nextRow && !nextRow.classList.contains('quantity-row')) {
                const checkboxInRow = nextRow.querySelector('.record-checkbox');

                // Если установлен чекбокс в одной из строк ниже
                if (checkboxInRow && checkboxInRow.checked) {
                    showToast("Операция объединения прервана: выбрана строка для которой выбрано сопрставление.");
                    return; 
                }
                nextRow = nextRow.nextElementSibling; 
            }
        }

        // Если нет выбранных чекбоксов, выполняем объединение Quantity и скрытие строк
        const firstQuantity = parseFloat(document.getElementById(`hiddenQuantity_${firstIndex}`).value) || 0;
        const secondQuantity = parseFloat(document.getElementById(`quantityFilter_${secondIndex}`).value) || 0;
        const newQuantity = firstQuantity + secondQuantity;

        // Обновляем значение Quantity в первой строке
        document.getElementById(`hiddenQuantity_${firstIndex}`).value = newQuantity;
        document.getElementById(`quantityFilter_${firstIndex}`).value = newQuantity;

        // Скрываем вторую строку и обновляем поле Hidden
        secondRow.style.display = 'none';
        const hiddenField = secondRow.querySelector('.hiddenField');
        if (hiddenField) {
            hiddenField.value = 'True';
        }

        // Скрываем строки ниже второй строки, пока не встретим строку с классом quantity-row
        let nextRow = secondRow.nextElementSibling;
        while (nextRow && !nextRow.classList.contains('quantity-row')) {
            nextRow.style.display = 'none'; // Скрываем строку
            const hiddenFieldBelow = nextRow.querySelector('.hiddenField');
            if (hiddenFieldBelow) {
                hiddenFieldBelow.value = 'True'; // Устанавливаем значение Hidden в true
            }

            nextRow = nextRow.nextElementSibling; // Переходим к следующей строке
        }

        showToast(`Значение объединено Кол: ${newQuantity}`);
    }
</script>

<script>
    // Универсальная функция для расчета суммы элементов по переданному классу
    function calculateTotalSum(className) {
        const elements = document.querySelectorAll(`.${className}`);
        let totalSum = 0;

        elements.forEach(element => {
            // Убираем пробелы из текста и преобразуем его в число
            const numericValue = parseFloat(element.textContent.replace(/\s/g, '')) || 0;
            totalSum += numericValue;
        });

        console.log(`Сумма для класса .${className}:`, totalSum);
    }

    // Функция для отслеживания изменений значений элементов по переданному классу
    function observeChanges(className) {
        const elements = document.querySelectorAll(`.${className}`);

        elements.forEach(element => {
            // Создаем новый MutationObserver для отслеживания изменений в элементе
            const observer = new MutationObserver(() => calculateTotalSum(className));

            // Настраиваем наблюдатель на изменения в тексте элемента
            observer.observe(element, { characterData: true, subtree: true, childList: true });
        });
    }

    // Пример использования
    observeChanges("purchasePrice"); // Отслеживаем изменения для элементов с классом 'purchasePrice'

    // Выполняем начальный расчет для класса 'purchasePrice'
    calculateTotalSum("purchasePrice");

</script>