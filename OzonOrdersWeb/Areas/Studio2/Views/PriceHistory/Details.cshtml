@model OzonRepositories.Data.Bitrix.PriceHistory
@{
    ViewData["Title"] = "Детали записи истории цен";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Детали записи</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                </svg>
                Редактировать
            </a>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                </svg>
                Назад
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">Информация о записи #@Model.Id</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">ID записи:</label>
                        <p class="mb-0">@Model.Id</p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Bitrix ID:</label>
                        <p class="mb-0">
                            <span class="badge bg-secondary">@Model.BitrixId</span>
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Артикул:</label>
                        <p class="mb-0">
                            <strong class="fs-5">@Model.Article</strong>
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Цена:</label>
                        <p class="mb-0">
                            <span class="fs-4 fw-bold text-primary">@Model.PriceValue.ToString("N2")</span>
                            <span class="badge bg-info ms-2">@Model.Currency</span>
                        </p>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Дата создания:</label>
                        <p class="mb-0">
                            <span class="d-block">@Model.CreateDateTime.ToString("dd.MM.yyyy")</span>
                            <small class="text-muted">@Model.CreateDateTime.ToString("HH:mm:ss")</small>
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Источник значения:</label>
                        <p class="mb-0">
                            @if (!string.IsNullOrEmpty(Model.ValueSource))
                            {
                                <span class="badge bg-primary">@Model.ValueSource</span>
                            }
                            else
                            {
                                <span class="text-muted">Не указан</span>
                            }
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Автор:</label>
                        <p class="mb-0">
                            @if (!string.IsNullOrEmpty(Model.Author))
                            {
                                <span>@Model.Author</span>
                            }
                            else
                            {
                                <span class="text-muted">Не указан</span>
                            }
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Статус:</label>
                        <p class="mb-0">
                            <span class="badge bg-success">Активная запись</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <div class="row">
            <div class="col-md-6">
                <a asp-action="SearchByArticle" asp-route-article="@Model.Article" class="btn btn-outline-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    Все записи этого артикула
                </a>
            </div>
            <div class="col-md-6 text-end">
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Вы уверены, что хотите удалить эту запись?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                            <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                        </svg>
                        Удалить запись
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: 1px solid rgba(0, 0, 0, 0.125);
        }
        .badge {
            font-size: 0.875rem;
            padding: 0.5em 0.75em;
        }
        .fw-bold.text-muted {
            color: #6c757d !important;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .fs-4 {
            font-size: 1.5rem !important;
        }
</style>
