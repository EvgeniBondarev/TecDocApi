@model OzonRepositories.Data.Bitrix.PriceHistory
@{
    ViewData["Title"] = "Редактирование записи";
}

<div class="container mt-4">
    <h2>Редактирование записи #@Model.Id</h2>
    
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="BitrixId" class="form-label"></label>
                            <input asp-for="BitrixId" class="form-control" />
                            <span asp-validation-for="BitrixId" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="Article" class="form-label"></label>
                            <input asp-for="Article" class="form-control" />
                            <span asp-validation-for="Article" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="PriceValue" class="form-label"></label>
                            <input asp-for="PriceValue" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="PriceValue" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" />
                            <span asp-validation-for="Currency" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="ValueSource" class="form-label"></label>
                            <input asp-for="ValueSource" class="form-control" />
                            <span asp-validation-for="ValueSource" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="Author" class="form-label"></label>
                            <input asp-for="Author" class="form-control" />
                            <span asp-validation-for="Author" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="CreateDateTime" class="form-label"></label>
                            <input asp-for="CreateDateTime" class="form-control" type="datetime-local" />
                            <span asp-validation-for="CreateDateTime" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="mt-3">
            <button type="submit" class="btn btn-success">Сохранить изменения</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}