@using OzonOrdersWeb.ViewModels.OrderViewModels


@model MultiplayEditOrderViewModel

@{
ViewData["Title"] = "Edit";
Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/table.css" />
<link rel="stylesheet" href="~/css/transaction.css" />
<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>

<script src="~/js/Studio2/Orders/CreateOrderToSupplierTransactionV2/generateInfoRow.js"></script>

<div class="d-flex align-items-center gap-2 flex-wrap mb-3">
    <button id="startButton" class="btn btn-primary">Загрузить доп. информацию</button>
    <div class="form-group mb-0">
        <label for="regionSelect" class="form-label visually-hidden">Регион</label>
        <select id="regionSelect" name="RegionCode" class="form-select form-select-sm">
            <option value="1" selected>Россия, Москва и область</option>
        </select>
    </div>
</div>

<hr />

<!-- Модальное окно со спиннером -->
<div class="modal fade" id="loadingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: transparent; border: none; box-shadow: none;">
            <div class="d-flex justify-content-center align-items-center" style="height: 150px;">
                <div class="spinner-border text-white" role="status" style="width: 4rem; height: 4rem;">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="messageContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 1050;">
    <div id="flashMessage" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <strong class="me-auto">Сообщение</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body">
            <span id="flashMessageText"></span>
        </div>
    </div>
</div>

<div class="modal fade" id="cartModal" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content rounded-3 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="cartModalLabel">Корзина</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body" id="cartModalBody">
                <!-- Контент корзины будет вставлен сюда -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

@if (Model.Orders.Count > 0)
{
    <form asp-area="Studio2" asp-controller="ShippedBySupplierTransaction" asp-action="CreateShippedBySupplierTransaction" id="createOrderForm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="RedirectPage" />
    
        @await Html.PartialAsync("_TransactionTable", Model)
    
        <div class="form-check ms-3">
            <input class="form-check-input" type="checkbox" id="ProcessIn1C" name="ProcessIn1C" value="true" checked>
            <label class="form-check-label" for="ProcessIn1C">
                Провести в 1С
            </label>
        </div>
        
            
        <!-- ================== МОДАЛЬНОЕ ОКНО ================== -->
        <div class="modal fade" id="transactionModal" tabindex="-1" aria-labelledby="transactionModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="transactionModalLabel">Данные документа</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="Contract" class="form-label">Договор</label>
                            <input type="text" id="Contract" name="Contract" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label for="NumberVh" class="form-label">Номер входящего</label>
                            <input type="text" id="NumberVh" name="NumberVh" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label for="DateVh" class="form-label">Дата входящего</label>
                            <input type="date"
                                   id="DateVh"
                                   name="DateVh"
                                   class="form-control"
                                   required
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        
                        <div class="mb-3">
                            <label for="TransactionComment" class="form-label">Комментарий</label>
                            <textarea id="TransactionComment" name="TransactionComment" class="form-control" rows="3" placeholder="Введите комментарий..."></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="button" id="confirmSubmit" class="btn btn-primary">Подтвердить и сохранить</button>
                    </div>
                </div>
            </div>
        </div>
        
        <input type="hidden" name="UserName" id="UserName" value="@User.Identity.Name"/>
        <input type="hidden" name="Page" id="Page" value="@Model.RedirectPage"/>

        <div class="form-group mt-3 d-flex justify-content-end">
            <div class="input-group">
                <span class="input-group-btn">
                    <input type="button" value="Сохранить" id="openModalBtn"
                           style="width: 170px;"
                           class="btn btn-primary"
                           data-bs-toggle="modal"
                           data-bs-target="#transactionModal" />
                </span>
            </div>
        </div>
    </form>
}
else
{
    <p>
        Нет выбранных заказов для проведения документа.<br/>
        Причина: <b>@ViewData["ErrorReason"]</b>
    </p>
    <ul>
        <li>Статус выбранного заказа должен быть <b>'Заказан поставщику'</b>.</li>
        <li>Все выбранные заказы должны принадлежать <b>одному поставщику</b>.</li>
        <li>Все выбранные заказы должны принадлежать <b>одному складу</b>.</li>
    </ul>
    @Html.Partial("_OrderStatusFlow")
}

<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">Создание журнала документов</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">К списку заказов</a>
</div>

<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myModalLabel">Поля не заполнены</h4>
            </div>
            <div class="modal-body">
                Одно или несколько полей не заполнены. Пожалуйста, заполните все поля перед отправкой формы.
            </div>
        </div>
    </div>
</div>


<!-- Модальное окно для отображения увеличенного изображения -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="Full Image" class="img-fluid rounded border">
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="DeletedOrders" name="DeletedOrders" />
@await Html.PartialAsync("_TransactionScript", Model)

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const openModalBtn = document.getElementById("openModalBtn");
        const processIn1CCheckbox = document.getElementById("ProcessIn1C");
        const form = document.getElementById("createOrderForm");

        const transactionModalEl = document.getElementById("transactionModal");
        const transactionModal = new bootstrap.Modal(transactionModalEl);

        const loadingModalEl = document.getElementById("loadingModal");
        const loadingModal = new bootstrap.Modal(loadingModalEl);

        // === Устанавливаем сегодняшнюю дату ===
        transactionModalEl.addEventListener("show.bs.modal", function () {
            const dateInput = document.getElementById("DateVh");
            if (dateInput && !dateInput.value) {
                const today = new Date().toISOString().split("T")[0];
                dateInput.value = today;
            }
        });

        // === Кнопка "Сохранить" ===
        openModalBtn.addEventListener("click", function (e) {
            e.preventDefault();

            if (processIn1CCheckbox.checked) {
                transactionModal.show();
            } else {
                showLoadingModal();
                form.submit();
            }
        });

        // === Подтверждение из модалки ===
        document.getElementById("confirmSubmit").addEventListener("click", function () {
            const contract = document.getElementById("Contract").value.trim();
            const numberVh = document.getElementById("NumberVh").value.trim();
            const dateVh = document.getElementById("DateVh").value;

            if (!contract || !numberVh || !dateVh) {
                alert("Пожалуйста, заполните все поля.");
                return;
            }

            transactionModal.hide();
            showLoadingModal();

            // отправляем форму
            form.submit();
        });

        // === Функция показа модального спиннера ===
        function showLoadingModal() {
            loadingModal.show();
        }

        // === Скрываем спиннер при возврате на страницу (например, после redirect) ===
        window.addEventListener("pageshow", () => {
            const modal = bootstrap.Modal.getInstance(loadingModalEl);
            if (modal) modal.hide();
        });
    });
</script>
