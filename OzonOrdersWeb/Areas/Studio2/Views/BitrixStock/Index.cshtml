                </div>

                <div class="mb-3">
                    ${response.detailInfo?.articleSchema?.dataSupplierArticleNumber || response.productInfo?.articlE_NUMBER || response.detailInfo?.supplier || response.productInfo?.manufacturer || response.detailInfo?.description || response.productInfo?.description
            ? `
