                                const title = attr.displayTitle || attr.description || '';
                                const value = attr.displayValue || '';
                                const isWeight = /Вес \[кг\]|Масса/i.test(title);
                
                                const displayValue = isWeight && value
                                    ? `<span class="weight-value"
                                             style="cursor: pointer; text-decoration: underline; color: blue;"
                                             data-weight="${value}"
                                             data-order-id="${orderId}">
                                           ${value} кг
                                       </span>`
                                    : value ? `- ${value.length > 15 ? value.slice(0, 15) + '...' : value}` : '';
                
                                return `<li title="${attr.description || ''} - ${value}">
                                            ${title.length > 15 ? title.slice(0, 15) + '...' : title} ${displayValue}
                                        </li>`;
                            }).join('')}
                    </ul>
                ` : ''}

                    <div class="form-group d-flex align-items-center gap-2">
                        <label for="ProductWeight_${orderId}" class="form-label mb-0">Вес:</label>
                        <input class="form-control form-control-sm product-weight-field" id="ProductWeight_${orderId}" style="width: 70px;" />
                    </div>
                </div>
            </div>
        </div>
        <div class="table-content" 
             style="width: 60%; height: 400px; overflow-y: auto;">
            ${generateStockTradeTable(orderId, [], pricesTradesoft, colorMap)}
            ${applyColumnState('.stock-trade-table')}
        </div>
    </div>
    `;
    }

    function deletePriceHistory(id, bitrixId) {
        if (!confirm('Вы уверены, что хотите удалить эту запись?')) {
            return false;
        }

        const token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: `/PriceHistory/Delete/${id}`,
            type: 'POST',
            headers: {
                'RequestVerificationToken': token,
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function(response) {
                if (response === 'ok') {
                    showNotification('Запись успешно удалена!', 'success');
                    loadPriceHistory(bitrixId); 
                } else {
                    showNotification('Ошибка при удалении записи', 'error');
                }
            },
            error: function(xhr, status, error) {
                showNotification('Ошибка сервера: ' + error, 'error');
            }
        });

        return false; // Предотвращаем стандартную отправку формы
    }

