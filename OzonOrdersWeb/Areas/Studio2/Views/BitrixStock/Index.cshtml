            if (ozonHtml) {
                $("#ozonDataSection").show();
                $("#ozonTableContainer").html(ozonHtml);

                const inputVal = parseFloat($('input[name="PriceValue"]').val()) || 0;
                recalcRanges(inputVal);
            }
        } catch (error) {
            console.error('Ошибка при обновлении данных Ozon:', error);
            $("#ozonTableContainer").empty();
        }
    });
</script>
