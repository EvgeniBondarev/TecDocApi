    // Очистка ошибок валидации
    function clearValidationErrors() {
        $('.text-danger small').text('');
        $('.form-control').removeClass('is-invalid');
    }

    // Показать ошибки валидации
    function showValidationErrors(errors) {
        clearValidationErrors();

        for (const field in errors) {
            if (errors.hasOwnProperty(field)) {
                const errorElement = $(`#${field.toLowerCase()}Error`);
                const inputElement = $(`[name="${field}"]`);

                if (errorElement.length && inputElement.length) {
                    errorElement.text(errors[field].join(', '));
                    inputElement.addClass('is-invalid');
                }
            }
        }
    }

    $(document).on('submit', '#priceHistoryForm', function (e) {
        e.preventDefault();

        const form = $(this);
        // Исправьте URL - добавьте слеш в начале и / перед Area
        const url = '/Studio2/PriceHistory/Create';
        const formData = form.serialize();

        // Получаем productId из формы
        const productId = $('#modalBitrixId').val(); // Или другого поля, где хранится productId
        console.log('Product ID:', productId);
        console.log('Отправка данных:', formData);
        console.log('URL:', url);

        // Показываем индикатор загрузки
        const submitBtn = form.find('button[type="submit"]');
        const originalText = submitBtn.html();
        submitBtn.html(`
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Добавление...
    `).prop('disabled', true);

        $.ajax({
            url: url,
            type: 'POST',
            data: formData,
            headers: {
                'RequestVerificationToken': getAntiXsrfToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function (result) {
                console.log('Успешный ответ:', result);
                if (result.success) {
                    showNotification('Запись успешно создана!', 'success');
                    const now = new Date().toISOString().slice(0, 16);
                    $('#modalCreateDateTime').val(now);
                    clearValidationErrors();

                    // Вызываем обновление истории цен после успешного добавления
                    if (productId) {
                        loadPriceHistory(productId);
                    } else {
                        console.warn('Product ID не найден для обновления истории');
                    }
                }
            },
            error: function (xhr, status, error) {
                console.log('Ошибка AJAX:', status, error, xhr.responseText);

                try {
                    const errorData = JSON.parse(xhr.responseText);
                    if (errorData.errors) {
                        showValidationErrors(errorData.errors);
                        showNotification('Пожалуйста, исправьте ошибки в форме', 'error');
                    } else {
                        showNotification(errorData.error || 'Ошибка при создании записи', 'error');
                    }
                } catch (e) {
                    showNotification('Ошибка сервера: ' + xhr.status, 'error');
                }
            },
            complete: function () {
                submitBtn.html(originalText).prop('disabled', false);
            }
        });
    });
    
    // Функция для показа уведомлений поверх всех окон
    function showNotification(message, type = 'info') {
        // Создаем контейнер для уведомлений если его нет
        let notificationContainer = document.getElementById('notification-container');
        if (!notificationContainer) {
            notificationContainer = document.createElement('div');
            notificationContainer.id = 'notification-container';
            notificationContainer.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 99999; display: flex; flex-direction: column; gap: 10px;';
            document.body.appendChild(notificationContainer);
        }

        // Создаем уведомление
        const toast = document.createElement('div');
        toast.className = `alert alert-${type} alert-dismissible fade show`;
        toast.style.cssText = 'min-width: 300px; max-width: 400px; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);';
        toast.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;

        // Добавляем уведомление в контейнер
        notificationContainer.appendChild(toast);

        // Инициализируем Bootstrap alert
        const bsAlert = new bootstrap.Alert(toast);

        // Автоматическое скрытие через 5 секунд
        setTimeout(() => {
            if (toast.parentNode) {
                bsAlert.close();
            }
        }, 5000);

        // Удаляем элемент из DOM после скрытия
        toast.addEventListener('closed.bs.alert', function () {
            if (toast.parentNode) {
                toast.parentNode.removeChild(toast);
            }
        });
    }

