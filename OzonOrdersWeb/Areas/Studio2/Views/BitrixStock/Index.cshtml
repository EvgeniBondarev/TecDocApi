    @functions {
        string BuildPageUrl(int page)
        {
            var query = new Dictionary<string, object?>
            {
                ["Page"] = page,
                ["PageSize"] = Model.Filter.PageSize,
                ["ProductId"] = Model.Filter.ProductId,
                ["Article"] = Model.Filter.Article,
                ["PreviewText"] = Model.Filter.PreviewText,
                ["Active"] = Model.Filter.Active,
                ["Available"] = Model.Filter.Available,
                ["Supplier"] = Model.Filter.Supplier,
                ["QuantityFrom"] = Model.Filter.QuantityFrom,
                ["QuantityTo"] = Model.Filter.QuantityTo,
                ["DateFrom"] = Model.Filter.DateFrom?.ToString("yyyy-MM-dd"),
                ["DateTo"] = Model.Filter.DateTo?.ToString("yyyy-MM-dd"),
                ["PriceValueFrom"] = Model.Filter.PriceValueFrom,
                ["PriceValueTo"] = Model.Filter.PriceValueTo,
                ["RegistrationPriceFrom"] = Model.Filter.RegistrationPriceFrom,
                ["RegistrationPriceTo"] = Model.Filter.RegistrationPriceTo,
                ["StoreId"] = Model.Filter.StoreId,
                ["StoreTitle"] = Model.Filter.StoreTitle,
                ["AmountFrom"] = Model.Filter.AmountFrom,
                ["AmountTo"] = Model.Filter.AmountTo,
                ["SortColumn"] = Model.Filter.SortColumn,
                ["SortDirection"] = Model.Filter.SortDirection,
                ["LoadOzonWarehouses"] = Model.Filter.LoadOzonWarehouses ? "true" : "false",
                ["OzonStoreTitle"] = Model.Filter.OzonStoreTitle,
                ["OzonAmountFrom"] = Model.Filter.OzonAmountFrom,
                ["OzonAmountTo"] = Model.Filter.OzonAmountTo
            };

            var queryString = string.Join("&", query
                .Where(kv => kv.Value != null)
                .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value.ToString()!)}"));

            return Url.Action("Index") + "?" + queryString;
        }
    }
    
    @{
        int totalPages = (int)Math.Ceiling((double)Model.Result.TotalCount / Model.Result.PageSize);
        int currentPage = Model.Result.Page;
    }

    <div class="pagination-wrapper d-flex justify-content-center">
        <div class="pagination-controls">
            @if (totalPages > 15)
            {
                int start, end;

                if (currentPage <= 8)
                {
                    start = 1;
                    end = 15;
                }
                else if (currentPage >= totalPages - 7)
                {
                    start = totalPages - 14;
                    end = totalPages;
                }
                else
                {
                    start = currentPage - 6;
                    end = currentPage + 8;
                }

                if (start > 1)
                {
                    <a href="@BuildPageUrl(1)" class="btn btn-primary">1</a>
                    <span>...</span>
                }

                for (int i = start; i <= end; i++)
                {
                    <a href="@BuildPageUrl(i)" class="btn btn-primary @(i == currentPage ? "active" : "")">@i</a>
                }

                if (end < totalPages)
                {
                    <span>...</span>
                    <a href="@BuildPageUrl(totalPages)" class="btn btn-primary">@totalPages</a>
                }
            }
            else
            {
                for (int i = 1; i <= totalPages; i++)
                {
                    <a href="@BuildPageUrl(i)" class="btn btn-primary @(i == currentPage ? "active" : "")">@i</a>
                }
            }
        </div>
    </div>


</div>

<script>
    window.suppliersData = @Html.Raw(Json.Serialize(Model.Suppliers));
    window.warehouseMappings = [
        @foreach (var mapping in Model.WarehousesmMappings)
        {
        <text>{ Id: @mapping.Id, 
                BitrixWarehouseName: "@mapping.BitrixWarehouseName", 
                OzonWarehouseName: "@mapping.OzonWarehouseName",
                OzonClientName: "@mapping.OzonClient.Name" },</text>
        }
    ];
    const rates = {
        'RUB': 1,
        'USD': parseFloat('@Model.RateUSD'.replace(',', '.')),
        'EUR': parseFloat('@Model.RateEUR'.replace(',', '.')),
        'BYN': parseFloat('@Model.RateBYN'.replace(',', '.'))
    };
    const ozonClientHistory = {};
    
    
    function handleEnter(event) {
        if (event.key === 'Enter') {
            event.preventDefault();
            document.getElementById('filterForm').submit();
        }
    }

    function fetchOzonData(article) {
        return $.ajax({
            url: '@Url.Action("GetOzonPrices", "BitrixStock")', // путь к вашему контроллеру
            type: "GET",
            data: { article: article }
        }).catch(error => {
            if (error.status === 500) {
                console.error('Ошибка 500 при получении данных из Ozon:', error.responseText);
            }
            return null;
        });
    }

    function GetTradesoftDataForBitrix(article, producer) {
        return $.ajax({
            url: '@Url.Action("GetTradesoftDataForBitrix", "Tradesoft")',
            type: "GET",
            data: { article: article, producer: producer }
        }).catch(error => {
            if (error.status === 500 || error.status === 404) {
                console.error('Ошибка 500 при получении данных от Tradesoft:', error);
            }
            return [];
        });
    }

    function GetZzapDataForBitrix(article, producer, regionCode = 1) {
        return $.ajax({
            url: '@Url.Action("GetZzapDataForBitrix", "Tradesoft")',
            type: "GET",
            data: { article: article, producer: producer, regionCode: regionCode }
        }).catch(error => {
            if (error.status === 500 || error.status === 404) {
                console.error('Ошибка 500 при получении данных от Zzap:', error);
            }
            return [];
        });
    }

    function GetAbcpDataForBitrix(article, producer) {
        return $.ajax({
            url: '@Url.Action("GetAbcpDataForBitrix", "Tradesoft")',
            type: "GET",
            data: { article: article, producer: producer }
        }).catch(error => {
            if (error.status === 500) {
                console.error('Ошибка 500 при получении данных от Abcp:', error);
            }
            return [];
        });
    }

    function GetAvdDataForBitrix(orderId) {
        return $.ajax({
            url: '@Url.Action("GetAvdDataForBitrix", "Tradesoft")',
            type: "GET",
            data: { orderId: orderId }
        }).catch(error => {
            if (error.status === 500 || error.status === 404) {
                console.error('Ошибка 500 при получении данных от Avd:', error);
            }
            return [];
        });
    }

    function GetCombinedDataForBitrix(article, producer, regionCode = 1, orderId = null) {
        let deferred = $.Deferred();

        $.when(
            GetTradesoftDataForBitrix(article, producer),
            GetZzapDataForBitrix(article, producer, regionCode),
            GetAbcpDataForBitrix(article, producer),
            orderId ? GetAvdDataForBitrix(orderId) : $.Deferred().resolve([]) 
        ).done(function (tradesoftItems, zzapItems, abcpItems, avdItems) {
            try {
                let tItems = Array.isArray(tradesoftItems?.[0]) ? tradesoftItems[0] : tradesoftItems || [];
                let zItems = Array.isArray(zzapItems?.[0]) ? zzapItems[0] : zzapItems || [];
                let aItems = Array.isArray(abcpItems?.[0]) ? abcpItems[0] : abcpItems || [];
                let vItems = Array.isArray(avdItems?.[0]) ? avdItems[0] : avdItems || [];

                deferred.resolve([...tItems, ...zItems, ...aItems, ...vItems]);
            } catch (e) {
                console.error("Ошибка при объединении данных:", e);
                deferred.resolve([]);
            }
        }).fail(function (error1, error2, error3, error4) {
            console.error("Не удалось загрузить данные от одного или нескольких источников");

            let tItems = (error1 && (error1.status === 500 || error1.status === 404)) ? [] : (error1 || []);
            let zItems = (error2 && (error2.status === 500 || error2.status === 404)) ? [] : (error2 || []);
            let aItems = (error3 && (error3.status === 500 || error3.status === 404)) ? [] : (error3 || []);
            let vItems = (error4 && (error4.status === 500 || error4.status === 404)) ? [] : (error4 || []);

            if (tItems.length > 0 || zItems.length > 0 || aItems.length > 0 || vItems.length > 0) {
                deferred.resolve([...tItems, ...zItems, ...aItems, ...vItems]);
            } else {
                deferred.reject(error1 || error2 || error3 || error4);
            }
        });

        return deferred.promise();
    }


    function fetchBitrixData(orderArticle) {
        return $.ajax({
            url: '@Url.Action("GetBitrixData", "Bitrix")',
            type: "GET",
            data: { article: orderArticle }
        }).catch(error => {
            if (error.status === 500) {
