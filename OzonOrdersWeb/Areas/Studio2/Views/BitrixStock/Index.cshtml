    function checkWarehouseConnection(ozonWarehouseName, bitrixData, clientName) {
       
        if (!window.warehouseMappings || !Array.isArray(window.warehouseMappings)) {
            return false;
        }
        console.log(ozonWarehouseName, bitrixData, clientName);

        const mapping = window.warehouseMappings.find(mapping =>
            mapping.OzonWarehouseName === ozonWarehouseName &&
            mapping.OzonClientName === clientName 
        );

        if (!mapping) {
            return false;
        }
        return true;
    }

    function updatePriceDisplay(orderId, indexRow) {
        const $priceLink = $(`.price-link[data-order-id="${orderId}"][data-index-row="${indexRow}"]`);
        const $priceBlock = $(`.cost-price-row[data-order-id="${orderId}"][data-index-row="${indexRow}"]`);
        const $weightInput = $(`#ProductWeight_${orderId}`);
        const $supplierSelect = $(`#SupplierId_${orderId}`);

        const weight = parseFloat(($weightInput.val() || '0').replace(',', '.')) || 0;
        const priceSite = $priceLink.data('site');

        // Вывод в консоль исходных данных
        console.log('====== РАСЧЕТ СТОИМОСТИ ======');
        console.log(`Заказ: ${orderId}, Строка: ${indexRow}`);
        console.log(`Сайт: ${priceSite}`);
        console.log(`Вес товара: ${weight} кг`);

        // Получаем данные из модели (предполагается, что suppliers доступен глобально)
        const supplierFromModel = window.suppliersData.find(s => s.site === priceSite);
        console.log(supplierFromModel);
         let weightFactor = 0;
        let costFactor = 1;
        let weightCurrency = 'RUB';

        if (supplierFromModel) {
            weightFactor = parseFloat((supplierFromModel.weightFactor || '0').toString().replace(',', '.')) || 0;
            costFactor = parseFloat((supplierFromModel.costFactor || '1').toString().replace(',', '.')) || 1;
            weightCurrency = supplierFromModel.weightFactorCurrencyDisplayName || 'RUB';
            console.log('Данные поставщика из модели:');
            console.log(`• weightFactor: ${weightFactor}`);
            console.log(`• costFactor: ${costFactor}`);
            console.log(`• weightCurrency: ${weightCurrency}`);
        } else {
            const supplierOptionBySite = $supplierSelect.find(`option[data-site="${priceSite}"]`);
            weightFactor = parseFloat((supplierOptionBySite.data('weight-factor') || '0').toString().replace(',', '.')) || 0;
            costFactor = parseFloat((supplierOptionBySite.data('cost-factor') || '1').toString().replace(',', '.')) || 1;
            weightCurrency = supplierOptionBySite.data('weight-currency-code') || 'RUB';
            console.log('Данные поставщика из выпадающего списка:');
            console.log(`• weightFactor: ${weightFactor}`);
            console.log(`• costFactor: ${costFactor}`);
            console.log(`• weightCurrency: ${weightCurrency}`);
        }

        const rawPrice = parseFloat(($priceLink.data('price') || '0').toString().replace(',', '.')) || 0;
        const priceCurrency = $priceLink.data('currency-code') || 'RUB';

        console.log('--- Данные о цене ---');
        console.log(`• Базовая цена: ${rawPrice} ${priceCurrency}`);

        const ratePrice = rates[priceCurrency] || 1;
        const rateWeight = rates[weightCurrency] || 1;

        console.log('--- Курсы валют ---');
        console.log(`• Курс ${priceCurrency}/RUB: ${ratePrice}`);
        console.log(`• Курс ${weightCurrency}/RUB: ${rateWeight}`);

        // Промежуточные расчеты
        const pricePerKgRUB = weightFactor * rateWeight;
        const totalWeightCost = weight * pricePerKgRUB;
        const purchasePriceRUB = rawPrice * costFactor * ratePrice;
        const totalRUB = Math.round(totalWeightCost + purchasePriceRUB);

        console.log('--- Промежуточные расчеты ---');
        console.log(`• Стоимость кг (weightFactor): ${weightFactor} × ${rateWeight} = ${pricePerKgRUB} RUB/кг`);
        console.log(`• Стоимость веса: ${weight} кг × ${pricePerKgRUB} RUB/кг = ${totalWeightCost} RUB`);
        console.log(`• Цена закупки: ${rawPrice} × ${costFactor} × ${ratePrice} = ${purchasePriceRUB} RUB`);
        console.log(`• Итоговая стоимость: ${totalWeightCost} + ${purchasePriceRUB} = ${totalRUB} RUB`);

        const formattedTotalRUB = totalRUB.toLocaleString('ru-RU');
        const displayText = `${formattedTotalRUB} ₽`;

        console.log('--- Результат ---');
        console.log(`• Отображаемая цена: ${displayText}`);
        console.log('==============================');

        $priceBlock.text(displayText);
        $priceBlock.attr('data-value', totalRUB);

        if (window.tradesofDataCache && window.tradesofDataCache[orderId] && window.tradesofDataCache[orderId][indexRow]) {
            window.tradesofDataCache[orderId][indexRow].costPrice = totalRUB;
            window.tradesofDataCache[orderId][indexRow].costPriceFormatted = displayText;
        }
    }

