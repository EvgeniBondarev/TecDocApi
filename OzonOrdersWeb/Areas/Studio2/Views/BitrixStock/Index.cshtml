                const productId = this.getAttribute('data-active-id');
                console.log(productId);
                const currentStatus = this.textContent.trim();

                const confirmationMessage = currentStatus === 'Да'
                    ? 'Вы уверены, что хотите деактивировать этот элемент?'
                    : 'Вы уверены, что хотите активировать этот элемент?';

                if (!confirm(confirmationMessage)) {
                    return;
                }

                const originalText = this.textContent;
                this.textContent = 'Загрузка...';
                this.style.opacity = '0.6';

                fetch('@Url.Action("ToggleActiveStatus", "BitrixStock", new { area = "Studio2" })', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(parseInt(productId))
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showNotification(data.message, 'success');

                            this.textContent = data.isActive ? 'Активен' : 'Неактивен';
                            this.style.opacity = '1';

                            setTimeout(() => {
                                location.reload();
                            }, 500);
                        } else {
                            // Показываем ошибку
                            showNotification(data.message || 'Произошла ошибка', 'danger');
                            this.textContent = originalText;
                            this.style.opacity = '1';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showNotification('Ошибка сети', 'danger');
                        this.textContent = originalText;
                        this.style.opacity = '1';
                    });
            });
        });
    });

