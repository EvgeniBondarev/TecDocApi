    // Функция загрузки истории цен
    function loadPriceHistory(bitrixId) {
        if (!bitrixId) {
            $("#historySpinner").hide();
            $("#priceHistoryTableContainer").html(`
            <div class="alert alert-warning">
                Bitrix ID не указан для загрузки истории
            </div>
        `);
            return;
        }

        $.ajax({
            url: `/Studio2/PriceHistory/SearchByBitrixId?bitrixId=${bitrixId}`,
            type: 'GET',
            beforeSend: function() {
                $("#historySpinner").show();
                $("#priceHistoryTableContainer").empty();
            },
            success: function(data) {
                $("#historySpinner").hide();
                const historyHtml = renderPriceHistoryTable(data);
                $("#priceHistoryTableContainer").html(historyHtml);
                if (data && data.length > 0 && data[0].priceValue !== null) {
                    const priceValue = parseFloat(data[0].priceValue);
                    $('input[name="PriceValue"]').val(priceValue.toFixed(2));
                }
            },
            error: function(xhr, status, error) {
                $("#historySpinner").hide();
                console.error("Ошибка при загрузке истории цен:", error);
                $("#priceHistoryTableContainer").html(`
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    Ошибка при загрузке истории цен: ${xhr.status} ${xhr.statusText}
                </div>
            `);
            }
        });
    }

    function formatNumber(value) {
        const number = parseFloat(value);
        if (isNaN(number)) return value;
        return Math.round(number).toLocaleString('ru-RU');
    }
    
    
    function recalcRanges(inputVal) {
        console.log('=== Запуск recalcRanges ===', { inputVal });

        // Проверяем, является ли значение 0, пустой строкой или null/undefined
        const isEmptyValue = inputVal === 0 || inputVal === '' || inputVal === null || inputVal === undefined;

        // Находим всех уникальных клиентов
        const clientCells = document.querySelectorAll('.client-cell[data-client-id]');
        const clients = Array.from(clientCells).map(cell => cell.getAttribute('data-client-id'));

        console.log('Найдено клиентов:', clients.length);

        clients.forEach(clientId => {
            // Находим все строки данного клиента
            const clientRows = document.querySelectorAll(`tr[data-client="${clientId}"]`);

            // Ищем данные для расчета
            let basePrice = 0;
            let minComm = 0;
            let maxComm = 0;

            clientRows.forEach(row => {
                const priceCell = row.querySelector('td.price-cell[data-key="price"]');
                const minCell = row.querySelector('td.price-cell[data-key="min_commission"]');
                const maxCell = row.querySelector('td.price-cell[data-key="max_commission"]');

                if (priceCell) basePrice = parseFloat(priceCell.dataset.value) || 0;
                if (minCell) minComm = parseFloat(minCell.dataset.value) || 0;
                if (maxCell) maxComm = parseFloat(maxCell.dataset.value) || 0;
            });

            let minVal, maxVal;

            if (isEmptyValue) {
                // Если значение пустое - заполняем прочерками
                minVal = '—';
                maxVal = '—';
            } else {
                // Обычный расчет
                minVal = Math.round(basePrice - inputVal - maxComm);
                maxVal = Math.round(basePrice - inputVal - minComm);
            }

            console.log(`Клиент ${clientId}:`, {basePrice, minComm, maxComm, minVal, maxVal});

            clientRows.forEach(row => {
                const minRangeCell = row.querySelector('span.price-range-min');
                const maxRangeCell = row.querySelector('span.price-range-max');

                if (minRangeCell) {
                    minRangeCell.textContent = minVal;
                    // Сохраняем числовое значение только если это не прочерк
                    if (!isEmptyValue) {
                        minRangeCell.dataset.value = minVal;
                    } else {
                        // Очищаем data-value для прочерков
                        delete minRangeCell.dataset.value;
                    }
                }
                if (maxRangeCell) {
                    maxRangeCell.textContent = maxVal;
                    // Сохраняем числовое значение только если это не прочерк
                    if (!isEmptyValue) {
                        maxRangeCell.dataset.value = maxVal;
                    } else {
                        // Очищаем data-value для прочерков
                        delete maxRangeCell.dataset.value;
                    }
                }
            });
        });
    }
    
