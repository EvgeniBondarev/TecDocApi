                    value: item.price?.min_commission ?? "-",
                    nameCssClass: "text-danger",
                    valueCssClass: "text-danger"
                },
                {
                    key: "price_range_max",
                    name: "Прибыль макс.",
                    value: "-",
                    nameCssClass: "text-success",
                    valueCssClass: "text-success"
                },
                {
                    key: "price_range_min",
                    name: "Прибыль мин.",
                    value: "-",
                    nameCssClass: "text-danger",
                    valueCssClass: "text-danger"
                },

                { key: "currency_code", name: "Валюта", value: item.price?.currency_code ?? "-" },
                { key: "auto_action_enabled", name: "Автоприменение акций", value: item.price?.auto_action_enabled ? "Да" : "Нет" },
                { key: "auto_add_to_ozon_actions_list_enabled", name: "Автодобавление в акции", value: item.price?.auto_add_to_ozon_actions_list_enabled ? "Да" : "Нет" }
            ];


            const c = item.commissions || {};
            const indx = item.price_indexes || {};
            const commissionTypes = [
                { key: "ozon_reward", name: "Комиссия за продажу (FBS)", value: item.price?.ozon_reward ?? "-" },
                { key: "sales_percent_fbs", name: "Процент комиссии за продажу (FBS)", value: c.sales_percent_fbs ?? "-" },
                { key: "acquiring", name: "Эквайринг", value: item.acquiring ? Number(item.acquiring).toFixed(2) : "-" },
                { key: "fbs_first_mile_max", name: "Максимальная комиссия за обработку отправления (FBS)", value: c.fbs_first_mile_max_amount ?? "-" },
                { key: "fbs_first_mile_min", name: "Минимальная комиссия за обработку отправления (FBS)", value: c.fbs_first_mile_min_amount ?? "-" },
                { key: "fbs_direct_flow_trans_max", name: "Магистраль до (FBS)", value: c.fbs_direct_flow_trans_max_amount ?? "-" },
                { key: "fbs_deliv_to_customer", name: "Последняя миля (FBS)", value: c.fbs_deliv_to_customer_amount ?? "-" },
                { key: "fbs_return_flow", name: "Комиссия за возврат и отмену, обработка отправления (FBS)", value: c.fbs_return_flow_amount ?? "-" },
                { key: "fbs_direct_flow_trans_min", name: "Магистраль от (FBS)", value: c.fbs_direct_flow_trans_min_amount ?? "-" },
                {
                    key: "price_index",
                    name: "Индекс цены",
                    value: indx.color_index ?? "WITHOUT_INDEX",
                    description: getColorIndexDescription(indx.color_index),
                    color: getColorIndexColor(indx.color_index)
                },
                {
                    key: "ozon_min_price",
                    name: "Мин. цена у конкурентов на Ozon",
                    value: indx.ozon_index_data?.min_price ?? "-"
                },
                {
                    key: "ozon_index_value",
                    name: "Индекс цены на Ozon",
                    value: indx.ozon_index_data?.price_index_value ?? "-"
                },

                {
                    key: "external_min_price",
                    name: "Мин. цена у конкурентов на другой площадке",
                    value: indx.external_index_data?.min_price ?? "-"
                },
                {
                    key: "external_index_value",
                    name: "Индекс цены на другой площадке",
                    value: indx.external_index_data?.price_index_value ?? "-"
                },

                {
                    key: "self_marketplaces_min_price",
                    name: "Мин. цена вашего товара на других площадках",
                    value: indx.self_marketplaces_index_data?.min_price ?? "-"
                },
                {
                    key: "self_marketplaces_index_value",
                    name: "Индекс цены на ваших площадках",
                    value: indx.self_marketplaces_index_data?.price_index_value ?? "-"
                },
            ];

            let warehouseTypes = [];
            if (entry.WarehouseInfo?.result && entry.WarehouseInfo.result.length > 0) {
                warehouseTypes = entry.WarehouseInfo.result
                    .map(w => {
                        const present = w.present ?? 0;
                        const reserved = w.reserved ?? 0;
                        const hasConnection = w.hasBitrixConnection ?? false;
                        return {
                            key: w.warehouse_id ?? "",
                            name: w.warehouse_name ?? "-",
                            total: present,
                            reserved: reserved,
                            offer_id: item.offer_id,
                            product_id: item.product_id,
                            client: entry.Client,
                            hasBitrixConnection: hasConnection
                        };
                    })
                    .sort((a, b) => {
                        const aHasStock = a.total > 0;
                        const bHasStock = b.total > 0;
                        const aHasConnection = a.hasBitrixConnection;
                        const bHasConnection = b.hasBitrixConnection;

                        // Сначала склады с наличием и связью с Bitrix
                        if (aHasStock && aHasConnection && (!bHasStock || !bHasConnection)) return -1;
                        if (bHasStock && bHasConnection && (!aHasStock || !aHasConnection)) return 1;

                        // Затем склады с наличием
                        if (aHasStock && !bHasStock) return -1;
                        if (!aHasStock && bHasStock) return 1;

                        // Затем склады со связью с Bitrix
                        if (aHasConnection && !bHasConnection) return -1;
                        if (!aHasConnection && bHasConnection) return 1;

                        return a.name.localeCompare(b.name);
                    });
            }
            
            const maxRows = Math.max(priceTypes.length, commissionTypes.length, warehouseTypes.length);

            for (let i = 0; i < maxRows; i++) {
                const price = priceTypes[i];

                const commission = commissionTypes[i];
                let commissionValue = commission?.value ?? "";

                if (commission?.key === "price_index" && commission.color) {
                    commissionValue = `<span style="color: ${commission.color}; font-weight: bold;" 
            title="${commission.description}">
            ${commission.description}
        </span>`;
                }

                const warehouse = warehouseTypes[i];
                const hasConnection = warehouse?.hasBitrixConnection ?? false;

                const priceNameClass = price?.nameCssClass ? `price-name ${price.nameCssClass}` : 'price-name';
                const priceCellClass = price?.valueCssClass ? `price-cell text-end ${price.valueCssClass}` : 'price-cell text-end';

                const warehouseNameClass = hasConnection ? 'warehouse-name fw-bold text-success' : 'warehouse-name';
                const warehouseTotalClass = hasConnection ? 'warehouse-total text-end fw-bold text-success' : 'warehouse-total text-end';
                const warehouseReservedClass = hasConnection ? 'warehouse-reserved text-end fw-bold text-success' : 'warehouse-reserved text-end';
                
                const connectionIcon = hasConnection ?
                    '<i class="fas fa-link ms-1 text-success" title="Связан с Bitrix"></i>' :
                    '';
                html += `
                    <tr data-row="${i}" data-client="${clientId}">
                        ${i === 0 ? `
                        <td rowspan="${maxRows}" class="client-cell" data-type="client" data-client-id="${clientId}" title="Клиент">
                            ${clientName}
                            <br>
                            <a href="#"
                               class="update_price text-decoration-none"
                               data-offer-id="${warehouse?.offer_id ?? ""}"
                               data-product-id="${warehouse?.product_id ?? ""}"
                               data-client="${clientName}"
                               data-constant-index="0.91"
                               data-percent="2">
                                Обновить цены 
                                <small class="text-muted">
                                    (<span class="constant-index" contenteditable="true">0.91</span> / 
                                     <span class="percent" contenteditable="true">2</span>%)
                                </small>
                            </a>
                            <br>
                            <a href="#"
                               class="set_price text-decoration-none"
                               data-offer-id="${warehouse?.offer_id ?? ""}"
                               data-product-id="${warehouse?.product_id ?? ""}"
                               data-client="${clientName}"
                               data-price-value="${priceValue}">
                                Установить цену
                            </a>
                        </td>
                        ` : ""}
                        
                        <td class="${priceNameClass}" 
                            data-type="price-name" 
                            data-key="${price?.key ?? ""}" 
                            data-index="${i}" 
                            title="${price?.name ?? ""}"
                            style="${price?.key === 'true_price' ? 'color: orange !important;' : ''}">
                            ${price?.name ?? ""}
                        </td>
                        
                        <td class="${priceCellClass}"  
                            data-type="price" 
                            data-key="${price?.key ?? ""}" 
                            data-index="${i}" 
                            data-value="${price?.value ?? ""}" 
                            title="${price?.value ?? ""}"
                            style="${price?.key === 'true_price' ? 'color: orange !important;' : ''}">
                            ${
                                            price?.key === "price_range_min"
                                                ? `<span class="price-range-min" data-index="${i}">-</span>`
                                                : price?.key === "price_range_max"
                                                    ? `<span class="price-range-max" data-index="${i}">-</span>`
                                                    : (price?.value ? formatNumber(price.value) : "")
                                        }
                        </td>
                   
                        <td class="commission-name" 
                            data-type="commission-name" 
                            data-key="${commission?.key ?? ""}" 
                            data-index="${i}" 
                            title="${commission?.name ?? ""}">
                            ${commission?.name ?? ""}
                        </td>
                        <td class="commission-cell text-end" 
                            style="${commission?.key === 'ozon_index_value' && !isNaN(+commission?.value)
                                    ? (+commission.value <= 1 ? 'color:green!important;' : 'color:red!important;')
                                    : ''}" 
                            data-type="commission" 
                            data-key="${commission?.key ?? ""}" 
                            data-index="${i}" 
                            data-value="${commission?.value ?? ""}" 
                            title="${commission?.value ?? ""}">
                            ${commissionValue} ${commission?.key === 'ozon_index_value' ? oldIndexNote : ""}
                        </td>
                        <td class="${warehouseNameClass}" 
                            data-type="warehouse-name"
                            data-has-connection="${hasConnection}">
                            <a href="#" 
                               class="warehouse-link ${hasConnection ? 'text-success' : ''}"
                               data-key="${warehouse?.key ?? ""}"
                               data-offer-id="${warehouse?.offer_id ?? ""}"
                               data-product-id="${warehouse?.product_id ?? ""}"
                               data-client="${clientName}"
                               data-warehouse-id="${warehouse?.key ?? ""}"
                               data-warehouse-name="${warehouse?.name ?? ""}"
                               data-has-connection="${hasConnection}"
                               title="${warehouse?.name ?? ""}">
                                ${warehouse?.name ?? ""} ${connectionIcon}
                            </a>
                        </td>
                    
                        <td class="${warehouseTotalClass}" 
                            data-type="warehouse-total" 
                            data-key="${warehouse?.key ?? ""}" 
                            data-index="${i}" 
                            data-value="${warehouse?.total ?? ""}"
                            data-has-connection="${hasConnection}"
                            title="Всего: ${warehouse?.total ?? "-"}">
                            <a href="#"
                               class="warehouse-set-link ${hasConnection ? 'text-success' : ''}"
                               data-key="${warehouse?.key ?? ""}"
                               data-offer-id="${warehouse?.offer_id ?? ""}"
                               data-product-id="${warehouse?.product_id ?? ""}"
                               data-client="${clientName}"
                               data-warehouse-id="${warehouse?.key ?? ""}"
                               data-warehouse-name="${warehouse?.name ?? ""}"
                               data-total="${warehouse?.total ?? 0}"
                               data-has-connection="${hasConnection}"
                               title="${warehouse?.name ?? ""}">
                               ${warehouse?.total ?? ""}
                            </a>
                        </td>
                        <td class="${warehouseReservedClass}" 
                            data-type="warehouse-reserved" 
                            data-key="${warehouse?.key ?? ""}" 
                            data-index="${i}" 
                            data-value="${warehouse?.reserved ?? ""}"
                            data-has-connection="${hasConnection}"
                            title="Зарезервировано: ${warehouse?.reserved ?? "-"}">
                            ${warehouse?.reserved ?? ""}
                        </td>
                        
                        ${i === 0 ? `<td rowspan="${maxRows}" class="currency-cell text-end" data-type="currency" data-value="${currency}" title="Валюта">${currency}</td>` : ""}
                    </tr>
                    `;

            }
        });
        saveOzonHistory(history);
        html += "</tbody></table>";
        return html;
    }

    function renderOrderDetailedInformationForBitrix(response, pricesTradesoft) {
