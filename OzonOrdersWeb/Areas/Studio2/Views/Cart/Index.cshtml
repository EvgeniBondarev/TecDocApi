@using OzonDomains.Models
@using OzonOrdersWeb.Areas.Studio2.ViewModels.CartViewModels
@model List<OzonDomains.Models.OrderCarts.OrderCart>

@{
    int currentPage = ViewBag.CurrentPage as int? ?? 1; 
    int totalPages = ViewBag.TotalPages;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">Корзины заказов</h2>

    <form asp-area="Studio2" asp-controller="Cart" asp-action="UpdateCache" method="post" class="mb-0">
        <button type="submit" title="Обновить кеш корзины" class="btn btn-link p-0" style="text-decoration: none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                 class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                      d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 
                      .908-.417A6 6 0 1 1 8 2z"></path>
                <path
                    d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 
                    0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"></path>
            </svg>
        </button>
    </form>
</div>


<table class="table table-striped">
    <thead>
    @Html.Partial("_StandartOrderTableHead")
    <tbody>
    @foreach (var cart in Model)
    {
        <tr>
            <td colspan="15" class="bg-light text-dark">
                <div class="d-flex justify-content-between align-items-center px-2 py-1">
                    <div class="text-nowrap">
                        <strong>ID:</strong> @cart.Id &nbsp;  &nbsp;
                        <strong>Провайдер:</strong> @cart.Provider &nbsp;  &nbsp;
                        <strong>Создан:</strong> @cart.CreatedAt.ToString("HH:mm dd.MM.yyyy")
                    </div>
                    <div class="text-nowrap">
                        <a href="@Url.Action("ViewSummary", "OrderSummary", new { area = "Studio2", cartId = cart.Id })"
                           target="_blank"
                           class="text-primary text-decoration-none">
                            Посмотреть сводку заказа
                        </a>
                    </div>
                </div>
            </td>
        </tr>
        @foreach (var item in cart.OrderItems)
        {
            @if (item.StudioOrder != null)
            {
                @Html.Partial("_StandartCartOrderRow", new CartViewModel()
                                                            {
                                                                Order = item.StudioOrder,
                                                                Id = item.Id,
                                                                ItemId = item.ItemId,
                                                                OrderItemCode = item.OrderItemCode,
                                                                ItemStatus = item.ItemStatus?.Name,
                                                                Quantity = item.Quantity
                                                            })
            }
            else
            {
                <em>—</em>
            }
        }

    }
    </tbody>
</table>

<nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination d-flex justify-content-center flex-wrap">
        @if (totalPages > 15)
        {
            if (currentPage <= 8)
            {
                for (int i = 1; i <= 10; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(i)">@i</a>
                    </li>
                }
                <li class="page-item disabled"><span class="page-link">...</span></li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@(totalPages)">@totalPages</a>
                </li>
            }
            else if (currentPage >= totalPages - 7)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="1">1</a>
                </li>
                <li class="page-item disabled"><span class="page-link">...</span></li>
                @for (int i = totalPages - 9; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(i)">@i</a>
                    </li>
                }
            }
            else
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="1">1</a>
                </li>
                <li class="page-item disabled"><span class="page-link">...</span></li>

                @for (int i = currentPage - 5; i <= currentPage + 5; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(i)">@i</a>
                    </li>
                }

                <li class="page-item disabled"><span class="page-link">...</span></li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@(totalPages)">@totalPages</a>
                </li>
            }
        }
        else
        {
            for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(i)">@i</a>
                </li>
            }
        }

    </ul>
</nav>



@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const items = [];

            document.querySelectorAll('tr[data-order-item-code]').forEach(row => {
                const code = row.getAttribute('data-order-item-code');
                const id = row.getAttribute('data-order-item-id');
                if (code && id) {
                    items.push({ id: id, code: code });
                }
            });

            if (items.length > 0) {
                fetch('/Studio2/Tradesoft/UpdateItemsStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(items)
                });
            }
        });
    </script>
}
