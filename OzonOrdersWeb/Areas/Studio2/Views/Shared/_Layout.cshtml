    <!-- Chat widget -->
    <div class="chat-widget-new">
        <button id="chatToggle" class="btn btn-primary chat-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#chatCollapse" aria-expanded="false">
            i
            <span id="chatBadge" class="d-none"></span>
        </button>
        <div class="collapse" id="chatCollapse">
            <div class="card shadow-lg rounded-2xl chat-card d-flex flex-column">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Процессы</span>
                    <button id="chatClose" type="button" class="btn-close"></button>
                </div>
                <div id="chatBody" class="card-body chat-body flex-grow-1 px-2">
                    <!-- Сообщения будут загружаться сюда -->
                </div>
                <div class="card-footer p-2">
                    
                </div>
            </div>
        </div>
    </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Восстановление сообщений из localStorage
        function loadMessages() {
            const stored = localStorage.getItem('chatMessages');
            if (!stored) return;
            const msgs = JSON.parse(stored);
            const body = document.getElementById('chatBody');
            body.innerHTML = '';
            msgs.forEach(m => {
                const div = document.createElement('div');
                div.className = 'message mb-2';
                div.innerHTML = '<strong>' + m.from + ':</strong> ' + m.text;
                body.appendChild(div);
            });
            body.scrollTop = body.scrollHeight;
        }

        // Сохранение нового сообщения
        function saveMessage(from, text) {
            let msgs = JSON.parse(localStorage.getItem('chatMessages') || '[]');
            msgs.push({ from, text });
            localStorage.setItem('chatMessages', JSON.stringify(msgs));
        }

        document.addEventListener('DOMContentLoaded', () => {
            const chatCollapse = document.getElementById('chatCollapse');
            const chatToggle = document.getElementById('chatToggle');
            const chatClose = document.getElementById('chatClose');
            const chatBadge = document.getElementById('chatBadge');

            // Показать бейдж, если есть непросмотренные сообщения
            const messages = localStorage.getItem('chatMessages');
            const wasViewed = localStorage.getItem('chatViewed') === 'true';
            if (messages && !wasViewed) {
                chatBadge.classList.remove('d-none');
            }

            // Загрузка при разворачивании
            chatCollapse.addEventListener('shown.bs.collapse', () => {
                loadMessages();
                chatToggle.style.opacity = '0';
                chatToggle.style.pointerEvents = 'none';
                chatBadge.classList.add('d-none'); // убираем бейдж
                localStorage.setItem('chatViewed', 'true'); // помечаем как просмотрено
            });

            chatCollapse.addEventListener('hidden.bs.collapse', () => {
                chatToggle.style.opacity = '1';
                chatToggle.style.pointerEvents = 'auto';
            });

            chatClose.addEventListener('click', () => {
                bootstrap.Collapse.getInstance(chatCollapse).hide();
            });

            // SignalR
            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/notificationHub')
                .build();

            connection.start().then(() => console.log('Connected')).catch(err => console.error(err));

            connection.on('PopupNotification', (message) => {
                const now = new Date();
                const formattedDateTime = now.toLocaleString('ru-RU', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                }).replace(',', '');

                saveMessage(formattedDateTime, message);

                if (!chatCollapse.classList.contains('show')) {
                    chatBadge.classList.remove('d-none');
                    localStorage.setItem('chatViewed', 'false'); // новое сообщение — не просмотрено
                }

                if (chatCollapse.classList.contains('show')) {
                    const body = document.getElementById('chatBody');
                    const div = document.createElement('div');
                    div.className = 'message mb-2';
                    div.innerHTML = `<strong>${formattedDateTime}:</strong> ${message}`;
                    body.appendChild(div);
                    body.scrollTop = body.scrollHeight;
                }
            });
        });
    </script>


    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    function updateTable() {
        var button = document.getElementById('updateButton');
        var spinner = document.getElementById('spinner');
        var buttonText = document.getElementById('buttonText');

        button.disabled = true;
        spinner.classList.remove('visually-hidden');
        buttonText.textContent = 'Обновление...';

    }
</script>