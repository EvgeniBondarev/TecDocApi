@using System.Web
@model List<Servcies.HangfireService.Models.JobDto>

<!-- Модальное окно для данных -->
<div class="modal fade" id="dataModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Данные задания</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre id="modalDataContent" class="p-3 bg-light rounded modal-pre-wrap"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

<style>
    .modal-pre-wrap {
        white-space: pre-wrap;
        word-break: break-all;
        overflow-wrap: break-word;
    }
    .json-short {
        font-family: monospace;
        background-color: #f8f9fa;
        padding: 2px 4px;
        border-radius: 3px;
        display: inline-block;
        max-width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .action-link {
        cursor: pointer;
    }
    .action-link:hover {
        text-decoration: underline;
    }
</style>

<div class="table-responsive">
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Задание</th>
                <th>Поставлено в очередь</th>
                <th>Данные</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                var jsonData = job.Args != null ? 
                    Newtonsoft.Json.JsonConvert.SerializeObject(job.Args, Newtonsoft.Json.Formatting.Indented) : 
                    "{}";
                var shortData = jsonData.Length > 30 ? jsonData.Substring(0, 30) + "..." : jsonData;
                var dataId = "data-" + Guid.NewGuid().ToString("N");
                
                <tr>
                    <td>@job.Id</td>
                    <td>@job.MethodName</td>
                    <td>@job.EnqueuedAt?.ToString("HH:mm dd.MM.yyyy")</td>
                    <td>
                        <div id="@dataId" class="d-none">@jsonData</div>
                        <a href="#" class="text-decoration-none show-data" 
                           data-data-id="@dataId"
                           title="@jsonData">
                            <pre class="mb-0 d-inline json-short">@shortData</pre>
                        </a>
                    </td>
                    <td  class="text-center align-middle">
                        <a href="#" class="btn btn-sm btn-outline-danger"
                           onclick="return confirmDelete('@job.Id', '@job.MethodName');">
                            <i class="fas fa-trash-alt"></i> Удалить
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Нет заданий в очереди</div>
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Инициализация тултипов
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Обработка кликов для показа данных
        document.querySelectorAll('.show-data').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const dataId = this.getAttribute('data-data-id');
                const dataContent = document.getElementById(dataId).textContent;
                
                const modal = new bootstrap.Modal(document.getElementById('dataModal'));
                const preElement = document.getElementById('modalDataContent');
                
                preElement.className = 'p-3 bg-light rounded modal-pre-wrap';
                preElement.textContent = dataContent;
                
                modal.show();
            });
        });
    });

    function confirmDelete(jobId, methodName) {
        if (confirm(`Вы уверены, что хотите удалить задание ${jobId} (${methodName})?`)) {
            deleteJob(jobId);
        }
        return false;
    }

    function deleteJob(jobId) {
        fetch('@Url.Action("DeleteJob", "HangfireQueue")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify({ jobId: jobId })
        })
        .then(response => {
            if (response.ok) {
                location.reload();
            } else {
                alert("Ошибка при удалении задания");
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert("Произошла ошибка при выполнении запроса");
        });
    }
</script>