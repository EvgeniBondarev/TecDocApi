@using Servcies.HangfireService.Models
@model IEnumerable<JobDto>

@{
var methodColors = new Dictionary<string, string>();
var colorPalette = new[] {
"#4e79a7", "#f28e2c", "#e15759", "#76b7b2", "#59a14f",
"#edc948", "#b07aa1", "#ff9da7", "#9c755f", "#bab0ab"
};
int colorIndex = 0;

foreach (var method in Model
.Where(j => !string.IsNullOrEmpty(j.MethodName))
.Select(j => j.MethodName)
.Distinct())
{
methodColors[method] = colorPalette[colorIndex % colorPalette.Length];
colorIndex++;
}

var chartData = Model
.Where(j => j.SucceededAt.HasValue && j.Duration.HasValue)
.OrderBy(j => j.SucceededAt)
.Select(j => new {
time = j.SucceededAt.Value.ToString("yyyy-MM-ddTHH:mm:ss"), // ISO формат для корректной обработки в JS
durationMs = j.Duration.Value,
durationMin = j.Duration.Value / 60000.0,
method = j.MethodName,
color = methodColors[j.MethodName]
})
.ToList();

var jsonData = System.Text.Json.JsonSerializer.Serialize(chartData);
}

<div style="height: 500px; display: flex; align-items: center; justify-content: center; padding: 0 40px;">
    <canvas id="jobChart" style="height: 400px !important; width: 100%;"></canvas>
</div>

<div class="mt-3">
    <h5>Легенда:</h5>
    <ul>
        @foreach (var kv in methodColors)
        {
        <li>
            <span style="display:inline-block;width:12px;height:12px;background:@kv.Value;margin-right:5px;"></span>
            @kv.Key
        </li>
        }
    </ul>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.0"></script>

<script>
    const rawData = @Html.Raw(jsonData);

    const labels = rawData.map(d => new Date(d.time).toLocaleString());
    const data = {
        labels: labels,
        datasets: [{
            label: 'Длительность (мин)',
            data: rawData.map(d => d.durationMin),
            backgroundColor: rawData.map(d => d.color),
            hoverOffset: 4
        }]
    };

    const config = {
        type: 'bar',
        data: data,
        maintainAspectRatio: false,
        options: {
            responsive: true,
            plugins: {
                tooltip: {
                    callbacks: {
                        label: function (context) {
                            const index = context.dataIndex;
                            const method = rawData[index].method;
                            const durationMin = rawData[index].durationMin.toFixed(2);
                            const durationMs = rawData[index].durationMs;
                            return `${method}: ${durationMin} мин (${durationMs} мс)`;
                        }
                    }
                },
                zoom: {
                    zoom: {
                        wheel: { enabled: true },
                        pinch: { enabled: true },
                        mode: 'x',
                    },
                    pan: {
                        enabled: true,
                        mode: 'x',
                    },
                    limits: {
                        x: { min: 0, max: rawData.length - 1 },
                    }
                },
                legend: {
                    display: false
                }
            },
            scales: {
                x: {
                    title: {
                        display: true,
                        text: 'Время завершения'
                    },
                    ticks: {
                        maxRotation: 45,
                        minRotation: 45
                    }
                },
                y: {
                    title: {
                        display: true,
                        text: 'Длительность (минуты)'
                    }
                }
            }
        }
    };

    const ctx = document.getElementById('jobChart').getContext('2d');
    new Chart(ctx, config);
</script>
