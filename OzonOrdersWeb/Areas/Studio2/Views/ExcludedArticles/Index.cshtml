@model IEnumerable<OzonDomains.Models.ExcludedArticle>

@{
    ViewData["Title"] = "Список исключённых артикулов";
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 20;
    int totalCount = ViewBag.TotalCount ?? Model.Count();
    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Добавить
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Исключённых артикулов пока нет. 
            <a asp-action="Create" class="alert-link">Добавьте первый</a>.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Артикул</th>
                                <th>Клиент</th>
                                <th style="width:200px;">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.Article</strong></td>
                                <td>@item.OzonClient?.Name</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-warning me-1" asp-action="Edit" asp-route-id="@item.Id">
                                        <i class="bi bi-pencil-square"></i> Изменить
                                    </a>
                                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">
                                        <i class="bi bi-trash"></i> Удалить
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
<div class="mt-3 d-flex justify-content-center">
    <nav>
        <ul class="pagination">
            <li class="page-item @(page == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(page - 1)">«</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(page == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(page + 1)">»</a>
            </li>
        </ul>
    </nav>
</div>
<style>
    .table th {
        font-weight: 600;
        font-size: 0.9rem;
    }
    .table td {
        vertical-align: middle;
    }
</style>
