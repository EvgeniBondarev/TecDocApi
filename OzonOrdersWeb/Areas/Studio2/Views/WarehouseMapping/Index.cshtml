@using OzonDomains.Models
@using Servcies.FiltersServcies.FilterModels
@using Servcies.FiltersServcies.SortModels

@model OzonOrdersWeb.Areas.Studio2.ViewModels.Warehouse.WarehouseMappingViewModel<WarehouseMapping, WarehouseMappingFilterModel>

@{
    ViewData["Title"] = "Связи складов";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script asp-src-include="~/js/**/*.js"></script>
<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>

<style>
    .underline-input input, .underline-input select {
        border: none;
        border-bottom: 1px solid #ced4da;
        outline: none;
        width: 100%;
        box-shadow: none;
        border-radius: 0;
    }
</style>

<div class="container ">
    <div class="row">
        <div>
            <div class="card">
                <div class="card-header">
                    <h2>Связи складов (Bitrix ↔ Ozon)</h2>
                    <p>
                        <a asp-action="Create">Новая связь</a>
                    </p>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>
                                        <form asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="DelSortStateCookie" method="post">
                                            <button type="submit" class="btn btn-link" style="width: 18px; height: 18px;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
                                                    <path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0"></path>
                                                </svg>
                                                <span class="visually-hidden">Button</span>
                                            </button>
                                        </form>
                                    </th>
                                    <th>
                                        <a class="text-dark" asp-action="Index" asp-route-sortOrder="@ViewData["IdSort"]">
                                            <small>@(ViewData["IdSort"]?.ToString() == "IdAsc" ? "ID↑" : "ID↓")</small>
                                        </a>
                                    </th>
                                    <th>
                                        <a class="text-dark" asp-action="Index" asp-route-sortOrder="@ViewData["ClientNameSort"]">
                                            <small>@(ViewData["ClientNameSort"]?.ToString() == "ClientNameAsc" ? "Клиент↑" : "Клиент↓")</small>
                                        </a>
                                    </th>
                                    <th>
                                        <a class="text-dark" asp-action="Index" asp-route-sortOrder="@ViewData["BitrixWarehouseSort"]">
                                            <small>@(ViewData["BitrixWarehouseSort"]?.ToString() == "BitrixWarehouseAsc" ? "Bitrix склад↑" : "Bitrix склад↓")</small>
                                        </a>
                                    </th>
                                    <th>
                                        <a class="text-dark" asp-action="Index" asp-route-sortOrder="@ViewData["OzonWarehouseSort"]">
                                            <small>@(ViewData["OzonWarehouseSort"]?.ToString() == "OzonWarehouseAsc" ? "Ozon склад↑" : "Ozon склад↓")</small>
                                        </a>
                                    </th>
                                    <th>Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <form id="filterForm" asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="Index" method="post">
                                    <td>
                                        <button type="button" class="btn btn-link ml-2" onclick="clearForm()" style="margin-top: -9px;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
                                                <path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0"></path>
                                            </svg>
                                            <span class="visually-hidden">Button</span>
                                        </button>
                                    </td>
                                    <td></td>
                                    <td>
                                        <input asp-for="@Model.FilterModel.ClientName" name="ClientName" class="form-control form-control-sm" placeholder="Клиент" />
                                    </td>
                                    <td>
                                        <input asp-for="@Model.FilterModel.BitrixWarehouseName" name="BitrixWarehouseName" class="form-control form-control-sm" placeholder="Bitrix склад" />
                                    </td>
                                    <td>
                                        <input asp-for="@Model.FilterModel.OzonWarehouseName" name="OzonWarehouseName" class="form-control form-control-sm" placeholder="Ozon склад" />
                                    </td>
                                    <td>
                                        <button type="submit" class="btn btn-primary btn-sm">Применить</button>
                                    </td>
                                    </form>
                                </tr>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td></td>
                                        <td>@item.Id</td>
                                        <td>
                                            <form asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="Edit" method="post" oninput="toggleSaveButton(this)">
                                                <input type="hidden" name="Id" value="@item.Id" />
                                                <input type="hidden" name="BitrixWarehouseName" value="@item.BitrixWarehouseName" />
                                                <input type="hidden" name="OzonWarehouseName" value="@item.OzonWarehouseName" />
                                                <div class="underline-input">
                                                    <select name="OzonClientId" class="form-control form-control-sm">
                                                        <option value="">@(item.OzonClientId.HasValue ? item.OzonClient?.Name : "Выберите клиента")</option>
                                                        @foreach (var client in ViewBag.Clients as SelectList)
                                                        {
                                                            <option value="@client.Value" selected="@(client.Value == item.OzonClientId?.ToString())">@client.Text</option>
                                                        }
                                                    </select>
                                                </div>
                                                <button type="submit" class="btn btn-link" style="display: none;">Сохранить</button>
                                            </form>
                                        </td>
                                        <td>
                                            <form asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="Edit" method="post" oninput="toggleSaveButton(this)">
                                                <input type="hidden" name="Id" value="@item.Id" />
                                                <input type="hidden" name="OzonClientId" value="@item.OzonClientId" />
                                                <input type="hidden" name="OzonWarehouseName" value="@item.OzonWarehouseName" />
                                                <div class="underline-input">
                                                    <input type="text" name="BitrixWarehouseName" class="form-control form-control-sm" value="@item.BitrixWarehouseName" placeholder="Bitrix склад" />
                                                </div>
                                                <button type="submit" class="btn btn-link" style="display: none;">Сохранить</button>
                                            </form>
                                        </td>
                                        <td>
                                            <form asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="Edit" method="post" oninput="toggleSaveButton(this)">
                                                <input type="hidden" name="Id" value="@item.Id" />
                                                <input type="hidden" name="OzonClientId" value="@item.OzonClientId" />
                                                <input type="hidden" name="BitrixWarehouseName" value="@item.BitrixWarehouseName" />
                                                <div class="underline-input">
                                                    <input type="text" name="OzonWarehouseName" class="form-control form-control-sm" value="@item.OzonWarehouseName" placeholder="Ozon склад" />
                                                </div>
                                                <button type="submit" class="btn btn-link" style="display: none;">Сохранить</button>
                                            </form>
                                        </td>
                                        <td>
                                            <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@item.Id">Детали</a> 
                                            <a class="btn btn-sm btn-primary" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="pagination-wrapper d-flex justify-content-center">
                            <div class="pagination-controls">
                                @if (Model.TotalPages > 15)
                                {
                                    @if (Model.PageNumber <= 8)
                                    {
                                        @for (int i = 1; i <= 15; i++)
                                        {
                                            <a asp-action="Index" asp-route-page="@(i)" class="btn btn-primary @(i == Model.PageNumber ? "active" : "")">@i</a>
                                        }
                                        <span>...</span>
                                        <a asp-action="Index" asp-route-page="@Model.TotalPages" class="btn btn-primary">@(Model.TotalPages)</a>
                                    }
                                    else if (Model.PageNumber >= Model.TotalPages - 7)
                                    {
                                        <a asp-action="Index" asp-route-page="1" class="btn btn-primary">1</a>
                                        <span>...</span>
                                        @for (int i = Model.TotalPages - 14; i <= Model.TotalPages; i++)
                                        {
                                            <a asp-action="Index" asp-route-page="@(i)" class="btn btn-primary @(i == Model.PageNumber ? "active" : "")">@i</a>
                                        }
                                    }
                                    else
                                    {
                                        <a asp-action="Index" asp-route-page="1" class="btn btn-primary">1</a>
                                        <span>...</span>
                                        @for (int i = Model.PageNumber - 6; i <= Model.PageNumber + 8; i++)
                                        {
                                            <a asp-action="Index" asp-route-page="@(i)" class="btn btn-primary @(i == Model.PageNumber ? "active" : "")">@i</a>
                                        }
                                        <span>...</span>
                                        <a asp-action="Index" asp-route-page="@Model.TotalPages" class="btn btn-primary">@(Model.TotalPages)</a>
                                    }
                                }
                                else
                                {
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <a asp-action="Index" asp-route-page="@(i)" class="btn btn-primary @(i == Model.PageNumber ? "active" : "")">@i</a>
                                    }
                                }
                            </div>
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleSaveButton(form) {
        $(form).find('button[type="submit"]').show();
    }

    function clearForm() {
        document.getElementById('filterForm').reset();
        document.getElementById('filterForm').submit();
    }

    // Обработка нажатия Enter в полях фильтра
    document.querySelectorAll('#filterForm input').forEach(input => {
        input.addEventListener('keypress', function(event) {
            if (event.key === 'Enter') {
                document.getElementById('filterForm').submit();
                event.preventDefault();
            }
        });
    });

    // Инициализация исходных значений при загрузке
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('input[type="text"], select').forEach(function(input) {
            input.dataset.initialValue = input.value;
        });
    });
</script>