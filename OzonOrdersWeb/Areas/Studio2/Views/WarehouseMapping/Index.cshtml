@model List<OzonDomains.Models.WarehouseMapping>
@{
    ViewData["Title"] = "Связи складов";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Связи складов (Bitrix ↔ Ozon)</h2>
        <div>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Новая связь
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Связи складов не найдены. <a asp-action="Create" class="alert-link">Создайте первую запись</a>.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header bg-light">
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-0">Всего связей: @Model.Count</h5>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Клиент</th>
                                <th>Bitrix склад</th>
                                <th>Ozon склад</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td><strong>@(item.OzonClient?.Name ?? "Не указан")</strong></td>
                                    <td>@item.BitrixWarehouseName</td>
                                    <td>@item.OzonWarehouseName</td>
                                    <td>
                                        <a asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Детали</a>
                                        <a asp-area="Studio2" asp-controller="WarehouseMapping" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>