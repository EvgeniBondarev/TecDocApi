<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OzonOrdersWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        scrollbar-width: thin;
        scrollbar-color: rgba(0, 0, 0, 0.5) transparent;
        
        .pagination-wrapper {
            display: flex;
            align-items: center; 
        }

        /* Для веб-браузеров на основе WebKit (Chrome, Safari) */
        ::-webkit-scrollbar {
            width: 7px; /* Ширина вертикальной полосы прокрутки */
            height: 7px; /* Высота горизонтальной полосы прокрутки */
        }

        ::-webkit-scrollbar-track {
            background: transparent; /* Фон полосы прокрутки */
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.3); /* Цвет ползунка прокрутки */
        }

        .btn-link svg {
            transition: transform 0.1s ease; /* Плавное увеличение */
        }

        .btn-link:hover svg {
            transform: scale(1.2); /* Увеличиваем SVG на 20% */
        }
        .chat-widget-new {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1050;
        }

        .chat-toggle {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            transition: opacity 0.3s;
        }

        .chat-card {
            width: 600px;
            height: 600px; /* Увеличена высота */
            display: flex;
            flex-direction: column;
        }

        .card-header {
            flex-shrink: 0;
        }

        .chat-body {
            flex-grow: 1;
            overflow-y: auto;
            padding: 15px;
            max-height: none; /* Убрано ограничение максимальной высоты */
            word-wrap: break-word;
            white-space: pre-wrap; /* Сохраняет форматирование текста с переносами строк */
        }

        #chatBadge {
            position: absolute;
            top: 10px;
            left: 10px;
            width: 10px;
            height: 10px;
            background-color: #EE204D;
            border-radius: 50%;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            
            <div class="container-fluid">
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 d-flex">
                        <!-- Главная вкладка PIM -->
