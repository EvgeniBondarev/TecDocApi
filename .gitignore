# ============================================
# Environment variables and secrets
# ============================================
.env
.env.local
.env.*.local
.env.*
.docker.env
docker.env
!.env.example

# ============================================
# Configuration files with secrets
# ============================================
# AppSettings files that may contain connection strings or secrets
# Keep appsettings.json but ignore files with actual secrets

# Development config with real connection strings (contains secrets)
**/appsettings.Development.json
!**/appsettings.Development.json.example

# Production configs with secrets (should not be in repo)
**/appsettings.Production.json
**/appsettings.*.Production.json

# User-specific/local configuration files
**/appsettings.*.local.json
**/appsettings.local.json
**/*.local.json

# Override files
**/appsettings.*.override.json
**/appsettings.override.json

# Any appsettings files in root (if any)
appsettings.*.json
!appsettings.json

# Local smoke-test inputs and generated reports
api_test_report_*.csv
api_test_report_*.md
*test_articles*.txt

